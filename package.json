{
  "name": "ascend",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "npx ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "clean": "rm -rf .next",
    "rebuild": "npm run clean && npm run build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest __tests__/unit",
    "test:components": "jest --project components",
    "reindex:jobs": "ts-node -r tsconfig-paths/register --project tsconfig.scripts.json scripts/reindex-jobs.ts",
    "ingest:load-csv": "ts-node scripts/ingestion/load-csv.ts",
    "ingest:load-manual": "ts-node scripts/ingestion/load-manual.ts",
    "ingest:parse": "ts-node --project tsconfig.ingest.json scripts/ingestion/parser.ts",
    "ingest:embed": "ts-node --project tsconfig.ingest.json scripts/ingestion/embed.ts",
    "ingest:taxonomy": "ts-node --project tsconfig.ingest.json scripts/ingestion/generate-taxonomy.ts",
    "ingest:insights": "ts-node --project tsconfig.ingest.json scripts/ingestion/company-insights.ts",
    "ingest:stats": "ts-node --project tsconfig.ingest.json scripts/ingestion/stats.ts",
    "ingest:kaggle": "ts-node --project tsconfig.ingest.json scripts/ingestion/sources/kaggle.ts",
    "ingest:adzuna": "ts-node --project tsconfig.ingest.json scripts/ingestion/sources/adzuna.ts",
    "ingest:rss": "ts-node --project tsconfig.ingest.json scripts/ingestion/sources/naukri-rss.ts",
    "ingest:careers": "ts-node --project tsconfig.ingest.json scripts/ingestion/sources/careers-pages.ts",
    "ingest:remoteok": "ts-node --project tsconfig.ingest.json scripts/ingestion/sources/remoteok.ts",
    "ingest:sources": "npm run ingest:remoteok && npm run ingest:adzuna && npm run ingest:rss",
    "ingest:all": "npm run ingest:sources && npm run ingest:parse && npm run ingest:embed && npm run ingest:taxonomy && npm run ingest:insights"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",

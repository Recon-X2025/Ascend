# ─── App ──────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                          # generate with: openssl rand -base64 32

# ─── Database (local PostgreSQL for now) ──────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ascend

# ─── Redis (local for now) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                           # leave blank for local

# ─── Storage (local for dev, vultr for production) ─────
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/tmp/ascend-storage
VULTR_STORAGE_ENDPOINT=                   # e.g. https://sgp1.vultrobjects.com
VULTR_STORAGE_ACCESS_KEY=
VULTR_STORAGE_SECRET_KEY=
VULTR_STORAGE_BUCKET=ascend-session-records

# ─── OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Email ────────────────────────────────────────────
RESEND_API_KEY=

# ─── AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                    # ingestion parser, embedder, resume/job features (get at platform.openai.com)

# ─── Job Search (Phase 5 — Typesense) ─────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=xyz
# (Use same key as in docker-compose.yml when running Typesense locally)

# ─── Job Search (RapidAPI etc.) ───────────────────────
RAPIDAPI_KEY=

# ─── JD Ingestion — Adzuna (Phase 0B, free tier) ──────
# https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ─── JD Scraping ──────────────────────────────────────
FIRECRAWL_API_KEY=

# ─── Payments (Phase 12 — Razorpay + Stripe) ─────────
# Razorpay (INR)
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# M-6: Optional separate webhook secret for mentorship escrow (defaults to RAZORPAY_WEBHOOK_SECRET)
# MENTORSHIP_RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_SEEKER_PREMIUM_MONTHLY=plan_xxxx
RAZORPAY_PLAN_SEEKER_PREMIUM_YEARLY=plan_xxxx
RAZORPAY_PLAN_RECRUITER_STARTER=plan_xxxx
RAZORPAY_PLAN_RECRUITER_PRO=plan_xxxx

# Stripe (USD / international)
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRICE_SEEKER_PREMIUM_MONTHLY=price_xxxx
STRIPE_PRICE_SEEKER_PREMIUM_YEARLY=price_xxxx
STRIPE_PRICE_RECRUITER_STARTER=price_xxxx
STRIPE_PRICE_RECRUITER_PRO=price_xxxx

# Pilot: set to true to allow new sign-ups (otherwise gated by feature flag seeker_pilot_open in DB)
SEEKER_PILOT_OPEN=true

# When set, skip sending verification email and create users as verified (for local testing without Resend)
# SKIP_VERIFICATION_EMAIL=true

# Cron (optional — for deactivate-expired-boosts)
CRON_SECRET=

# M-7: Meeting Room (Daily.co)
DAILYCO_API_KEY=
DAILYCO_DOMAIN=ascend
DAILYCO_WEBHOOK_SECRET=

# M-7: Ascend Steno (Deepgram + OpenAI)
DEEPGRAM_API_KEY=

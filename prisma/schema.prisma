generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  JOB_SEEKER
  RECRUITER
  COMPANY_ADMIN
  PLATFORM_ADMIN
}

enum UserPersona {
  ACTIVE_SEEKER
  PASSIVE_SEEKER
  EARLY_CAREER
  RECRUITER
}

// ─── DS-4B: Persona Deepening (UserCareerContext) ───────────────────────────

enum ExperienceBand {
  FRESHER
  EARLY
  MID
  SENIOR
  LEADERSHIP
}

enum CareerEmploymentStatus {
  EMPLOYED_ACTIVE
  EMPLOYED_LOOKING
  NOTICE_PERIOD
  UNEMPLOYED
  FREELANCE
  STUDENT
  SABBATICAL
}

enum CareerNoticePeriod {
  IMMEDIATE
  TWO_WEEKS
  ONE_MONTH
  TWO_MONTHS
  THREE_MONTHS
  NEGOTIABLE
}

enum SearchUrgency {
  BROWSING
  WARMING_UP
  ACTIVE
  URGENT
}

enum SearchReason {
  GROWTH
  COMPENSATION
  CULTURE
  LAYOFF
  RELOCATION
  CAREER_SWITCH
  FIRST_JOB
  RETURNING
  ENTREPRENEURSHIP
  CURIOSITY
}

enum PrimaryNeed {
  FIND_JOBS
  BENCHMARK_SALARY
  IMPROVE_RESUME
  FIND_MENTOR
  BUILD_NETWORK
  UNDERSTAND_COMPANIES
  PREPARE_INTERVIEWS
}

enum TargetCompanySizeBand {
  STARTUP
  SCALEUP
  MIDSIZE
  LARGE
  ENTERPRISE
  ANY
}

enum TargetGeography {
  INDIA_ONLY
  INDIA_TO_GLOBAL
  GLOBAL_ONLY
  FLEXIBLE
}

model UserCareerContext {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentRole         String?
  currentCompany      String?
  currentSalary       Int?
  yearsOfExperience   Int?
  experienceBand      ExperienceBand?

  targetRole          String?
  targetIndustry      String[]  @default([])
  targetCompanySize   TargetCompanySizeBand?
  targetCompanyType   String[]  @default([])
  targetSalaryMin     Int?
  targetLocations     String[]  @default([])
  openToRelocation    Boolean   @default(false)
  openToRemote        Boolean   @default(true)

  employmentStatus    CareerEmploymentStatus?
  noticePeriod        CareerNoticePeriod?
  urgency             SearchUrgency?
  searchReason        SearchReason?

  primaryNeed         PrimaryNeed?
  secondaryNeeds      PrimaryNeed[] @default([])

  isFirstJob          Boolean   @default(false)
  isSwitchingField    Boolean   @default(false)
  targetGeography     TargetGeography?

  completionScore     Int       @default(0)
  contextSetAt        DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

enum HiringVolume {
  OCCASIONAL
  REGULAR
  HIGH_VOLUME
}

enum RecruiterPainPoint {
  CANDIDATE_QUALITY
  TIME_TO_HIRE
  PIPELINE_VISIBILITY
  JD_WRITING
  SOURCING
  OFFER_ACCEPTANCE
}

model UserRecruiterContext {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  hiringFor           String[]  @default([])
  hiringVolume        HiringVolume?
  painPoints          RecruiterPainPoint[] @default([])

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  passwordHash       String?
  name               String?
  image              String?
  role               Role      @default(JOB_SEEKER)
  onboardingComplete Boolean   @default(false)
  persona            UserPersona?
  personaSetAt       DateTime?
  twoFactorEnabled   Boolean   @default(false)
  twoFactorSecret    String?
  bannedAt           DateTime?
  banReason          String?
  deletedAt          DateTime? // Phase 17: soft delete for account deletion requests
  termsAcceptedAt    DateTime?
  marketingConsent   Boolean   @default(false)
  preferredCurrency  String    @default("INR")  // ISO 4217 — salary display
  canFileDisputes    Boolean   @default(true)   // M-9: false after 2 rejected disputes
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  auditLogs           AuditLog[]
  auditLogsAsActor    AuditLog[]       @relation("AuditLogActor")
  dataRequests        DataRequest[]
  userReports         UserReport[]
  featureFlagsUpdated FeatureFlag[]
  jobSeekerProfile JobSeekerProfile?
  recruiterProfile RecruiterProfile?
  outcomeEvents    OutcomeEvent[]
  aiInteractions   AIInteraction[]
  userJourney      UserJourney?
  apiKeys          APIKey[]
  careerIntents    CareerIntent[]
  resumeVersions   ResumeVersion[]
  profileViewEventsAsViewer  ProfileViewEvent[] @relation("ProfileViewsAsViewer")
  profileViewEventsAsProfile ProfileViewEvent[] @relation("ProfileViewsAsProfile")
  jobApplications  JobApplication[]
  companyAdmins       CompanyAdmin[]
  companyBenefitRatings CompanyBenefitRating[]
  companyReviews      CompanyReview[]
  companyReviewVotes  CompanyReviewVote[]
  interviewReviews    InterviewReview[]
  interviewVotes       InterviewVote[]
  salaryReports       SalaryReport[]
  companyQAs          CompanyQA[]
  companyQAVotes      CompanyQAVote[]
  jobPosts            JobPost[]
  savedJobs           SavedJob[]
  savedSearches       SavedSearch[]
  jobAlerts           JobAlert[]
  searchHistories     SearchHistory[]
  fitScores             FitScore[]
  fitScoreHistory       FitScoreHistory[]
  optimisationSessions  OptimisationSession[]
  notifications         Notification[]
  subscription          UserSubscription?
  resumeOptimisationCredits ResumeOptimisationCredit?
  paymentEvents         PaymentEvent[]
  resumeUnlocksAsRecruiter ResumeUnlock[] @relation("RecruiterUnlocks")
  unlockedBy            ResumeUnlock[]    @relation("SeekerUnlocks")
  connectionsInitiated  Connection[]       @relation("ConnectionsInitiated")
  connectionsReceived   Connection[]     @relation("ConnectionsReceived")
  companyFollows        CompanyFollow[]
  conversationsAsA      Conversation[]    @relation("ConversationA")
  conversationsAsB      Conversation[]   @relation("ConversationB")
  messagesSent          Message[]
  signalFeed            CareerSignal[]    @relation("SignalFeed")
  signalsActed          CareerSignal[]    @relation("SignalActor")
  careerContext         UserCareerContext?
  recruiterContext      UserRecruiterContext?
  mentorProfile         MentorProfile?
  menteeSessions        MentorSession[]       @relation("MenteeSession")
  menteeApplications    MentorApplication[]   @relation("MenteeApplications")
  mentorContracts       MentorshipContract[]  @relation("MentorContracts")
  menteeContracts       MentorshipContract[]  @relation("MenteeContracts")
  escrowAsMentor        MentorshipEscrow[]    @relation("EscrowMentor")
  escrowAsMentee        MentorshipEscrow[]    @relation("EscrowMentee")
  paymentModeAcknowledgements PaymentModeAcknowledgement[]
  mentorOutcomes        MentorshipOutcome[]   @relation("MentorOutcomes")
  menteeOutcomes        MentorshipOutcome[]   @relation("MenteeOutcomes")
  mentorCertificates    MentorCertificate[]   @relation("MentorCertificates")  // BL-14 (as mentee)
  mentorTierHistory    MentorTierHistory[]   @relation("MentorTierHistory")
  contractSignatures    ContractSignature[]   @relation("ContractSignatures")
  menteeReadiness       MenteeReadinessCheck?
  circleMembers         CircleMember[]        @relation("CircleMembers")  // M-12
  mentorCircles         MentorshipCircle[]    @relation("MentorCircles")    // M-12
  mentorFollowsAsFollower MentorFollow[]     @relation("MentorFollowsAsFollower")  // BL-7
  mentorFollowsAsMentor   MentorFollow[]     @relation("MentorFollowsAsMentor")    // BL-7
  mentorPosts             MentorPost[]       @relation("MentorPosts")            // BL-8
  mentorArticles          MentorArticle[]    @relation("MentorArticles")        // BL-13
  mentorNewsletters       MentorNewsletter[] @relation("MentorNewsletters")     // BL-13
  mentorNewsletterSubscribers MentorNewsletterSubscriber[] @relation("MentorNewsletterSubscribers")  // BL-13
  newsletterSubscriptions MentorNewsletterSubscriber[] @relation("NewsletterSubscriptions")       // BL-13
  careerMilestones        CareerMilestone[]  @relation("CareerMilestones")      // BL-10
  cohortMemberships       CohortMember[]     @relation("CohortMembers")          // BL-9
  cohortThreads           CohortThread[]     @relation("CohortThreads")         // BL-9
  verificationAuditLogsAdmin VerificationAuditLog[]
  candidateInsightSnapshot    CandidateInsightSnapshot?
  coverLetters                CoverLetter[]
  interviewPreps              InterviewPrep[]
  profileOptimiserResult      ProfileOptimiserResult?
  jobDismissals               JobDismissal[]
  interviewScorecards         InterviewScorecard[]
  companyEmployees            CompanyEmployee[]
  jobReferralsAsReferrer      JobReferral[]
  // Phase 18: B2B / Enterprise
  companyApiKeysCreated      CompanyApiKey[]
  bulkImportJobsInitiated    BulkImportJob[]
  // Phase 19: Growth & Virality
  referralCode                ReferralCode?
  referredBy                  Referral?       @relation("ReferredReferrals")
  referrals                   Referral[]      @relation("ReferrerReferrals")
  shareEvents                 ShareEvent[]
  endorserEndorsements        ProfileEndorsement[] @relation("EndorserEndorsements")
  recipientEndorsements       ProfileEndorsement[]  @relation("RecipientEndorsements")
  referralPremiumUntil        DateTime?       // 30-day premium reward (no monetary payout yet)
  // Phase 22: Marketplace & Career Services
  marketplaceProvider        MarketplaceProvider?
  seekerResumeReviews         ResumeReviewOrder[]   @relation("SeekerResumeReviews")
  seekerMockInterviews        MockInterviewBooking[] @relation("SeekerMockInterviews")
  seekerCoachingSessions      CoachingSession[]     @relation("SeekerCoachingSessions")
  providerReviewsGiven       ProviderReview[]
  courseClicks                CourseClick[]
  profileBadges               ProfileBadge[]
  // M-16: Mentorship Ops
  mentorshipAuditLogsAsActor  MentorshipAuditLog[]
  opsAlertsResolved           OpsAlert[]
  // M-15: Legal Framework
  legalDocumentSignatures     LegalDocumentSignature[]
  // M-17: Mentorship Analytics
  mentorAnalyticsSnapshots    MentorAnalyticsSnapshot[]
  // GST Invoicing
  invoices                    Invoice[]
  billingProfile              BillingProfile?
}

enum ReferralStatus {
  CLICKED
  SIGNED_UP
  CONVERTED
  REWARDED
}

model ReferralCode {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String    @unique
  code        String    @unique // e.g. "ANANYA42" — human-readable
  clicks      Int       @default(0)
  signups     Int       @default(0)
  conversions Int       @default(0) // converted = completed onboarding
  createdAt   DateTime  @default(now())
  referrals   Referral[]
}

model Referral {
  id             String         @id @default(cuid())
  referrer       User           @relation("ReferrerReferrals", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId     String
  referred       User?          @relation("ReferredReferrals", fields: [referredId], references: [id], onDelete: SetNull)
  referredId     String?        @unique // null until they register
  referralCode   ReferralCode   @relation(fields: [codeId], references: [id], onDelete: Cascade)
  codeId         String
  referredEmail  String?        // captured at click if email provided
  status         ReferralStatus @default(CLICKED)
  clickedAt      DateTime      @default(now())
  signedUpAt     DateTime?
  convertedAt    DateTime?     // completed onboarding
  rewardGranted  Boolean       @default(false)
  rewardGrantedAt DateTime?

  @@index([referrerId])
  @@index([codeId])
  @@index([referredId])
}

model ShareEvent {
  id         String   @id @default(cuid())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  entityType String   // "JOB" | "COMPANY" | "PROFILE" | "SALARY_INSIGHT" | "MENTOR"
  entityId   String
  channel    String   // "COPY_LINK" | "WHATSAPP" | "LINKEDIN" | "TWITTER" | "EMAIL"
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, channel])
  @@index([createdAt])
}

model ProfileEndorsement {
  id          String   @id @default(cuid())
  endorser    User     @relation("EndorserEndorsements", fields: [endorserId], references: [id], onDelete: Cascade)
  endorserId  String
  recipient   User     @relation("RecipientEndorsements", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String
  skill       String   // skill name being endorsed
  createdAt   DateTime @default(now())

  @@unique([endorserId, recipientId, skill])
  @@index([recipientId])
  @@index([endorserId])
}

enum NotificationType {
  APPLICATION_STATUS_CHANGED
  JOB_ALERT_MATCH
  FIT_SCORE_IMPROVED
  PROFILE_VIEW
  RESUME_OPTIMISED
  CONNECTION_REQUEST
  MESSAGE_RECEIVED
  SYSTEM
  SKILL_ENDORSED
  MENTOR_SESSION_REQUESTED
  MENTOR_SESSION_ACCEPTED
  MENTOR_SESSION_DECLINED
  MENTOR_SESSION_COMPLETED
  MENTOR_VERIFICATION_SUBMITTED
  MENTOR_VERIFICATION_APPROVED
  MENTOR_VERIFICATION_REJECTED
  MENTOR_VERIFICATION_MORE_INFO
  MENTOR_REVERIFICATION_REQUIRED
  // Phase 22: Marketplace
  MARKETPLACE_ORDER_RECEIVED
  MARKETPLACE_ORDER_DELIVERED
  MARKETPLACE_ORDER_DISPUTED
  MARKETPLACE_PROVIDER_APPROVED
  MARKETPLACE_PROVIDER_REJECTED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

// ─── Job Seeker Profile (Phase 2) ─────────────────────────────────────────

enum NoticePeriod {
  IMMEDIATE
  FIFTEEN_DAYS
  THIRTY_DAYS
  SIXTY_DAYS
  NINETY_DAYS
  MORE_THAN_NINETY
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum ProfileVisibility {
  PUBLIC
  CONNECTIONS_ONLY
  RECRUITERS_ONLY
  PRIVATE
}

enum OpenToWorkVisibility {
  ALL
  RECRUITERS_ONLY
}

model JobSeekerProfile {
  id               String    @id @default(cuid())
  userId           String    @unique

  headline         String?
  summary          String?
  avatarUrl        String?
  bannerUrl        String?

  city             String?
  state            String?
  country          String?
  pinCode          String?

  currentCompany   String?
  currentRole      String?
  totalExpYears    Float?
  noticePeriod     NoticePeriod?
  currentCTC       Float?
  expectedCTC      Float?
  ctcCurrency      String?   @default("INR")
  workMode         WorkMode?

  openToWork       Boolean   @default(false)
  openToWorkVisibility OpenToWorkVisibility @default(RECRUITERS_ONLY)

  visibility       ProfileVisibility @default(PUBLIC)
  hideFromCompanies String[]         @default([])
  defaultResumeVisibility ResumeVisibility @default(RECRUITERS_ONLY)

  completionScore  Int       @default(0)
  profileViews     Int       @default(0)

  username         String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences      Experience[]
  educations       Education[]
  certifications  Certification[]
  projects         Project[]
  awards           Award[]
  languages        ProfileLanguage[]
  volunteerWork    VolunteerWork[]
  publications     Publication[]
  skills           UserSkill[]
  resumes          Resume[]
  careerIntents    CareerIntent[]
}

// ─── BL-1: Profile View Events (per-viewer storage for notifications) ───────

model ProfileViewEvent {
  id             String   @id @default(cuid())
  viewerId       String
  viewerCompanyId String?
  viewerCompanyName String?
  viewerRole     String?  // anonymised role e.g. "Recruiter" for premium
  profileUserId  String
  viewedAt       DateTime @default(now())

  viewer      User @relation("ProfileViewsAsViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profileUser User @relation("ProfileViewsAsProfile", fields: [profileUserId], references: [id], onDelete: Cascade)

  @@index([profileUserId, viewedAt])
  @@index([viewerId, viewedAt])
}

// ─── Resume Builder (Phase 2A) ─────────────────────────────────────────────

enum TargetLevel {
  IC
  TEAM_LEAD
  MANAGER
  DIRECTOR
  VP
  C_SUITE
}

model CareerIntent {
  id               String    @id @default(cuid())
  userId           String
  profileId        String

  targetRole       String
  targetIndustry   String
  targetLevel      TargetLevel
  careerGoal       String    @db.VarChar(300)
  switchingIndustry Boolean  @default(false)
  fromIndustry     String?
  toIndustry       String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile          JobSeekerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  resumeVersions   ResumeVersion[]

  @@index([userId])
  @@index([profileId])
}

enum ResumeVersionStatus {
  DRAFT
  COMPLETE
}

model ResumeVersion {
  id               String    @id @default(cuid())
  userId           String
  careerIntentId   String
  name             String
  templateId       String?
  contentSnapshot  Json?
  atsScore         Int?
  lastUsedAt       DateTime?
  lastUpdatedAt    DateTime?
  status           ResumeVersionStatus @default(DRAFT)
  jobPostId        Int?
  optimisedFrom    String?
  optimisationMeta Json?
  isDefault        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user                    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerIntent             CareerIntent           @relation(fields: [careerIntentId], references: [id], onDelete: Cascade)
  jobPost                  JobPost?                @relation("JobPostResumeVersions", fields: [jobPostId], references: [id], onDelete: SetNull)
  sourceVersion            ResumeVersion?          @relation("OptimisedVersions", fields: [optimisedFrom], references: [id], onDelete: SetNull)
  derivedVersions          ResumeVersion[]        @relation("OptimisedVersions")
  jobApplications          JobApplication[]
  optimisationSessionsAsBase    OptimisationSession[] @relation("BaseVersion")
  optimisationSessionsAsOutput  OptimisationSession[] @relation("OutputVersion")

  @@index([userId])
  @@index([careerIntentId])
  @@index([jobPostId])
  @@index([optimisedFrom])
}

// OptimisationMeta JSON shape (documented in code):
// { fitScoreBefore: number | null, fitScoreAfter: number | null, keywordsAdded: string[],
//   keywordsGapped: string[], bulletsRewritten: number, summaryRewritten: boolean }

// ─── Phase 4: Job Posts ───────────────────────────────────────────────────

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
  TEMPORARY
}

enum EducationLevel {
  ANY
  HIGH_SCHOOL
  DIPLOMA
  BACHELORS
  MASTERS
  PHD
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
}

// Phase 18B: Internal Job Board & Employee Mobility
enum JobVisibility {
  PUBLIC   // default — visible to all job seekers
  INTERNAL // verified employees of posting company only
  UNLISTED // direct link only, not in any listing
}

enum ScreeningQuestionType {
  TEXT
  YES_NO
  MULTIPLE_CHOICE
}

model JobPost {
  id               Int          @id @default(autoincrement())
  slug             String       @unique
  title            String
  description      String
  type             JobType
  workMode         WorkMode
  locations        String[]     @default([])
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String       @default("INR")
  salaryVisible    Boolean      @default(true)
  experienceMin    Int?
  experienceMax    Int?
  educationLevel   EducationLevel @default(ANY)
  openings         Int          @default(1)
  deadline         DateTime?
  easyApply        Boolean      @default(true)
  applicationUrl   String?
  tags             String[]    @default([])
  status               JobStatus     @default(DRAFT)
  visibility           JobVisibility @default(PUBLIC)
  internalFirstDays    Int?          // Phase 18B: switch to PUBLIC after N days (cron)
  allowAnonymousApply  Boolean       @default(false) // Phase 18B: hide applicant name until shortlisted
  viewCount            Int           @default(0)
  applicationCount     Int           @default(0)
  companyId            String?
  companyName          String?
  recruiterId          String
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  publishedAt          DateTime?

  resumeVersions       ResumeVersion[]       @relation("JobPostResumeVersions")
  jobReferrals         JobReferral[]
  optimisationSessions OptimisationSession[]
  companyRef           Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  recruiter            User                  @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  skills               JobPostSkill[]
  screeningQuestions   JobScreeningQuestion[]
  savedJobs            SavedJob[]
  fitScores            FitScore[]
  fitScoreHistory      FitScoreHistory[]
  jobApplications      JobApplication[]
  boosts               JobBoost[]
  messageContexts      Message[]
  signals              CareerSignal[]
  coverLetters         CoverLetter[]
  interviewPreps       InterviewPrep[]
  jobDismissals        JobDismissal[]
  hiringAnalyticsSnapshots HiringAnalyticsSnapshot[]
  interviewScorecards  InterviewScorecard[]
  diMetricsSnapshots   DIMetricsSnapshot[]
  boardSyndications   JobBoardSyndication[]  // BL-24

  @@index([slug])
  @@index([recruiterId])
  @@index([companyId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

enum OptimisationStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model OptimisationSession {
  id               String             @id @default(cuid())
  userId           String
  jobPostId        Int
  baseVersionId    String
  outputVersionId  String?
  status           OptimisationStatus @default(PENDING)
  fitScoreBefore   Float?
  fitScoreAfter    Float?
  gapAnalysis      Json?
  errorMessage     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPost       JobPost       @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  baseVersion   ResumeVersion @relation("BaseVersion", fields: [baseVersionId], references: [id], onDelete: Cascade)
  outputVersion ResumeVersion? @relation("OutputVersion", fields: [outputVersionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([jobPostId])
  @@index([baseVersionId])
  @@index([status])
}

model JobPostSkill {
  id         String   @id @default(cuid())
  jobPostId  Int
  skillId    String
  required   Boolean

  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobPostId, skillId])
  @@index([jobPostId])
}

model JobScreeningQuestion {
  id        String                 @id @default(cuid())
  jobPostId Int
  question  String
  type      ScreeningQuestionType
  options   String[]               @default([])
  required  Boolean                @default(true)
  order     Int                    @default(0)

  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@index([jobPostId])
}

model SavedJob {
  id         String   @id @default(cuid())
  userId     String
  jobPostId  Int
  savedAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPost JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@unique([userId, jobPostId])
  @@index([userId])
  @@index([jobPostId])
}

// ─── Phase 5: Search, Saved Searches, Alerts ─────────────────────────────────

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  query     String
  filters   Json?
  createdAt DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobAlerts JobAlert[]

  @@index([userId])
}

enum AlertFrequency {
  IMMEDIATE
  DAILY
  WEEKLY
}

model JobAlert {
  id             String         @id @default(cuid())
  userId         String
  savedSearchId  String?
  name           String
  query          String
  filters        Json?
  frequency      AlertFrequency
  active         Boolean        @default(true)
  lastSentAt     DateTime?
  createdAt      DateTime       @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedSearch SavedSearch? @relation(fields: [savedSearchId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([frequency, active])
}

model SearchHistory {
  id         String   @id @default(cuid())
  userId     String
  query      String
  filters    Json?
  searchedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, searchedAt(sort: Desc)])
}


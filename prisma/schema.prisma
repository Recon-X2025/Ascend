  actorId  String?
  endpoint String
  metadata Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([actorIp])
  @@index([actorId])
  @@index([createdAt])
}

enum ReportTargetType {
  JOB_POST
  COMPANY_REVIEW
  USER_PROFILE
  MESSAGE
  MENTOR_PROFILE
}

enum ReportReason {
  SPAM
  MISLEADING
  INAPPROPRIATE
  FAKE
  HARASSMENT
  OTHER
}

enum ReportStatus {

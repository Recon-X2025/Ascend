}

// ─── Phase 10B: Candidate Intelligence Dashboard ─────────────────────────────

model CandidateInsightSnapshot {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Market Value
  marketValueMin    Float?
  marketValueMax    Float?
  marketValueMedian Float?
  marketValueBasis  String? // e.g. "Based on 34 data points for Senior PM in Bangalore"
  marketValueAt     DateTime?

  // Profile Visibility Score (0–100)
  visibilityScore   Int?
  visibilityFactors Json? // { completeness: 80, keywordDensity: 60, recency: 70, ... }

  // Skills gap (top 5 missing skills vs target JDs)
  skillsGapData Json? // [{ skill, frequency, urgency }]
  skillsGapAt   DateTime?

  // Application performance
  appPerformanceData Json? // { applied, viewed, shortlisted, rejected, responseRate, ... }
  appPerformanceAt   DateTime?

  // Best time to apply heatmap data
  heatmapData Json? // { mon: { 9: 12, 10: 8, ... }, tue: { ... }, ... }
  heatmapAt   DateTime?

  computedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}


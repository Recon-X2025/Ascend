enum AIFeature {
  RESUME_BUILDER
  FIT_SCORER
  JD_OPTIMISER
  INTERVIEW_PREP
  CAREER_INTELLIGENCE
  SKILL_GAP_ANALYSER
  SALARY_PREDICTOR
  COVER_LETTER
  PROFILE_OPTIMISER
}

model OutcomeEvent {
  id        String           @id @default(cuid())
  userId    String
  eventType OutcomeEventType
  entityId  String?
  entityType String?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

model AIInteraction {
  id            String    @id @default(cuid())
  userId        String
  feature       AIFeature
  promptVersion String
  inputTokens   Int?
  outputTokens  Int?
  latencyMs     Int?
  rating        Int?
  metadata      Json?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feature])
  @@index([promptVersion])
  @@index([createdAt])
}

model UserJourney {
  id                    String   @id @default(cuid())
  userId                String   @unique
  resumesBuilt          Int      @default(0)
  fitScoresRun          Int      @default(0)
  optimiserSessions     Int      @default(0)
  applicationsSubmitted Int      @default(0)
  interviewsScheduled   Int      @default(0)
  offersReceived        Int      @default(0)
  lastActiveAt          DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model APIKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  requestCount Int      @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
}

// ─── Phase 3: Company Profiles ─────────────────────────────────────────────

enum CompanyType {
  PUBLIC
  PRIVATE
  NGO
  GOVERNMENT
  STARTUP
  OTHER
}

enum CompanySize {
  SIZE_1_10
  SIZE_11_50
  SIZE_51_200
  SIZE_201_500
  SIZE_501_1000
  SIZE_1001_PLUS
}

enum CompanyAdminRole {
  OWNER
  ADMIN
  MEMBER
}

enum CompanyMediaType {
  PHOTO
  VIDEO_EMBED
  VIRTUAL_TOUR
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
  REMOVED
}

enum EmploymentStatus {
  CURRENT
  FORMER
}

enum InterviewExperience {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
  VERY_HARD
}

enum CEOApproval {
  APPROVE
  DISAPPROVE
  NO_OPINION
}

enum InterviewResult {
  OFFER
  REJECTED
  WITHDREW
  PENDING
}

enum SalaryReportStatus {
  PENDING
  APPROVED
}

enum CompanyQAVoteType {
  UP
  DOWN
}

model Company {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  logo        String?
  banner      String?
  industry    String?
  type        CompanyType?
  size        CompanySize?
  founded     Int?
  hq          String?
  website     String?
  linkedin    String?
  twitter     String?
  facebook    String?
  instagram   String?
  glassdoor   String?
  mission     String?
  about       String?
  specialties String[]  @default([])
  verified          Boolean   @default(false)
  claimed           Boolean   @default(false)
  suspendedAt       DateTime?
  suspensionReason  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  admins     CompanyAdmin[]
  jobPosts   JobPost[]
  reviews    CompanyReview[]
  interviewReviews InterviewReview[]
  salaryReports    SalaryReport[]
  media      CompanyMedia[]
  benefits   CompanyBenefit[]
  qa         CompanyQA[]
  invites       CompanyInvite[]
  insight       CompanyInsight?
  subscription  CompanySubscription?
  boosts        JobBoost[]
  resumeUnlocks ResumeUnlock[]
  followers    CompanyFollow[]
  messageContexts Message[]
  signals       CareerSignal[]
  diMetricsEnabled Boolean @default(false)
  hiringAnalyticsSnapshots HiringAnalyticsSnapshot[]
  diMetricsSnapshots DIMetricsSnapshot[]
  verifiedDomains   String[]           @default([]) // Phase 18B: e.g. ["nexara.com"] for employee portal
  employees         CompanyEmployee[]
  // Phase 18: B2B / Enterprise & API Platform
  companyApiKeys    CompanyApiKey[]
  careersPageConfig CareersPageConfig?
  bulkImportJobs    BulkImportJob[]
  companyWebhooks   CompanyWebhook[]
  atsIntegration    AtsIntegration?
  ssoConfig         SsoConfig?
  atsWebhookEvents  AtsWebhookEvent[]

  @@index([slug])
  @@index([industry])
  @@index([verified])
}

// Phase 18B: verified employees (email domain match) — access to internal job portal
model CompanyEmployee {
  id         String   @id @default(cuid())
  userId     String
  companyId  String
  domain     String   // verified email domain e.g. "nexara.com"
  verifiedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model CompanyAdmin {
  id        String           @id @default(cuid())
  companyId String
  userId    String
  role      CompanyAdminRole
  createdAt DateTime        @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

model CompanyInvite {
  id        String   @id @default(cuid())
  companyId String
  email     String
  invitedBy String   // userId
  status    String   @default("PENDING") // PENDING | ACCEPTED | EXPIRED
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
}

model CompanyMedia {
  id        String          @id @default(cuid())
  companyId String
  type      CompanyMediaType
  url       String
  caption   String?
  order     Int             @default(0)
  createdAt DateTime        @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyBenefit {
  id        String   @id @default(cuid())
  companyId String
  label     String
  icon      String?
  emoji     String?
  order     Int      @default(0)

  company  Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ratings  CompanyBenefitRating[]
}

model CompanyBenefitRating {
  id        String @id @default(cuid())
  benefitId String
  userId    String
  rating    Int

  benefit CompanyBenefit @relation(fields: [benefitId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([benefitId, userId])
}

model CompanyReview {
  id               String           @id @default(cuid())
  companyId        String
  userId           String
  employmentStatus EmploymentStatus
  jobTitle         String
  location         String?
  startDate        DateTime?
  endDate          DateTime?
  overallRating    Int
  workLifeRating   Int?
  salaryRating     Int?
  cultureRating    Int?
  careerRating     Int?
  managementRating Int?
  recommend        Boolean
  ceoApproval      Boolean?
  pros             String    @db.Text
  cons             String    @db.Text
  advice           String?   @db.Text
  anonymous        Boolean          @default(false)
  status           ReviewStatus     @default(PENDING)
  flagReason       String?
  rejectionReason  String?          // set when status = REJECTED (admin reason)
  helpfulCount     Int              @default(0)
  notHelpfulCount  Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Phase 7: structured review fields
  headline            String?           // 80 chars max
  employmentType      EmploymentType?
  employmentStart    String?           // "YYYY-MM"
  employmentEnd       String?
  department          String?
  ceoApprovalRating   CEOApproval?     // Phase 7 enum (replaces ceoApproval boolean for new submissions)
  moderatedAt        DateTime?
  moderatedById      String?
  isVerifiedEmployee Boolean          @default(false)

  company Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes   CompanyReviewVote[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([companyId, status])
  @@index([userId])
}

model CompanyReviewVote {
  id       String  @id @default(cuid())
  reviewId String
  userId   String
  helpful  Boolean

  review CompanyReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model InterviewReview {
  id              String              @id @default(cuid())
  companyId       String
  userId          String
  jobTitle        String
  experience      InterviewExperience
  difficulty      InterviewDifficulty
  gotOffer        Boolean?
  process         String             @db.Text
  sampleQuestions String[]           @default([])
  durationDays    Int?
  anonymous       Boolean            @default(false)
  status          ReviewStatus       @default(PENDING)
  helpfulCount    Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Phase 7: extended interview review fields
  jobApplicationId String?
  interviewYear   Int?
  interviewResult InterviewResult?
  overallRating   Int?
  headline        String?
  processDesc     String?            @db.Text
  questions       String?            @db.Text
  tips            String?            @db.Text
  roundCount      Int?
  durationWeeks   Int?
  rejectionReason String?
  moderatedAt     DateTime?
  moderatedById   String?
  unhelpfulCount  Int                @default(0)

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobApplication JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  interviewVotes InterviewVote[]

  @@unique([userId, companyId, jobTitle])
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, userId, interviewYear])
}

model InterviewVote {
  id       String          @id @default(cuid())
  reviewId String
  userId   String
  helpful  Boolean

  review InterviewReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model SalaryReport {
  id               String            @id @default(cuid())
  companyId        String
  userId           String
  jobTitle         String
  experienceYears  Int
  location         String
  employmentType   EmploymentType
  baseSalary      Int
  bonus           Int?
  stockValue      Int?
  currency        String            @default("INR")
  anonymous       Boolean           @default(true)
  year            Int               @default(2024) // which year this salary applies to
  createdAt       DateTime          @default(now())

  // Phase 7: moderation and optional breakdown
  status           ReviewStatus @default(PENDING)
  rejectionReason  String?
  department       String?
  salaryAmount     Float?              // annual CTC (primary for Phase 7)
  baseSalaryOpt Float?              // optional breakdown
  bonusOpt      Float?
  stocksOpt     Float?              // ESOP/RSU annual value estimate

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId, jobTitle])
  @@index([jobTitle, location])
  @@index([companyId, status])
}

model CompanyQA {
  id          String    @id @default(cuid())
  companyId   String
  userId      String
  question    String    @db.Text
  answer      String?   @db.Text
  answeredBy  String?
  answeredAt  DateTime?
  upvotes     Int       @default(0)
  downvotes   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes   CompanyQAVote[]

  @@index([companyId])
}

model CompanyQAVote {
  id     String          @id @default(cuid())
  qaId   String
  userId String
  vote   CompanyQAVoteType

  qa   CompanyQA @relation(fields: [qaId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([qaId, userId])
}

// ─── Phase 0: JD Ingestion (Pre-Launch Data Layer) ───────────────────────────

model RawJD {
  id         String    @id @default(cuid())
  sourceUrl  String    @unique
  rawText    String    @db.Text
  hash       String    @unique // SHA-256 of rawText for dedup
  source     String    @default("manual") // "kaggle" | "adzuna" | "naukri-rss" | "careers-page" | "remoteok" | "manual"
  scrapedAt  DateTime  @default(now())
  parsedAt   DateTime?
  parseError String? // store error message if parsing failed

  parsedJD ParsedJD?
}

model ParsedJD {
  id              String   @id @default(cuid())
  rawJdId         String   @unique
  rawJD           RawJD    @relation(fields: [rawJdId], references: [id])

  title           String // normalised job title
  company         String? // company name extracted from JD — for Phase 0C insights
  seniority       String? // "Junior" | "Mid" | "Senior" | "Lead" | "Manager" | "Director" | "VP" | "C-Suite"
  industry        String?
  location        String? // normalised city name
  workMode        String? // "Remote" | "Hybrid" | "Onsite"
  skills          Json // { mustHave: string[], niceToHave: string[] }
  keywords        String[] // key terms extracted from JD
  responsibilities String[] // bullet points
  salaryMin       Int? // in INR per annum
  salaryMax       Int?
  currency        String?  @default("INR")
  tone            String? // "formal" | "startup" | "technical" | "creative"
  companySize     String? // "startup" | "sme" | "enterprise"
  functionalArea  String? // e.g. "Engineering", "Product" — for Phase 0C insights
  promptVersion   String // version of the parse prompt used
  parsedAt        DateTime @default(now())

  embedding       JDEmbedding?
  salarySignal    JDSalarySignal?
}

model JDEmbedding {
  id         String   @id @default(cuid())
  parsedJdId String  @unique
  parsedJD   ParsedJD @relation(fields: [parsedJdId], references: [id])
  embedding  Json // float[] stored as JSON (pgvector optional upgrade later)
  model      String // e.g. "text-embedding-3-small"
  createdAt  DateTime @default(now())
}

model JDSalarySignal {
  id         String   @id @default(cuid())
  parsedJdId String   @unique
  parsedJD   ParsedJD @relation(fields: [parsedJdId], references: [id])
  role       String
  seniority  String?
  location   String?
  salaryMin  Int
  salaryMax  Int
  currency   String   @default("INR")
  createdAt  DateTime @default(now())

  @@index([role, location])
}

// ─── Phase 0C: Company Intelligence (JD-derived signals) ─────────────────────

model CompanyInsight {
  id                  String   @id @default(cuid())
  // Identity — one set depending on aggregationType
  companyName         String?  // set when aggregationType = "company"
  industryLocation    String?  // set when aggregationType = "industry", e.g. "IT-Software::Bangalore"
  aggregationType     String   @default("company")  // "company" | "industry"
  companyId           String?  @unique // nullable — linked when Company record exists (1:1 with Company)

  totalJDsIndexed     Int      @default(0)
  activeRoleCount     Int      @default(0)
  topRoles            Json     @default("[]") // [{ title, count, seniority }]
  juniorPct           Float    @default(0)
  midPct              Float    @default(0)
  seniorPct           Float    @default(0)
  managerPct          Float    @default(0)
  remotePct           Float    @default(0)
  hybridPct           Float    @default(0)
  onsitePct           Float    @default(0)
  salaryMin           Int?
  salaryMax           Int?
  salaryMedian        Int?
  salaryDisclosureRate Float   @default(0)
  topSkills           Json     @default("[]") // [{ skill, count }]
  topLocations        Json     @default("[]") // [{ city, count }]
  primaryLocation     String?
  industries          Json     @default("[]") // [{ industry, count }]
  functionalAreas     Json     @default("[]") // [{ area, count }]
  hiringVelocity      String?  // "high" | "medium" | "low"
  lastComputedAt      DateTime @default(now())
  corpusSize          Int      @default(0)

  company             Company? @relation(fields: [companyId], references: [id])

  @@unique([companyName])
  @@unique([industryLocation])
  @@index([companyId])
  @@index([aggregationType])
}

// ─── Phase 12: Monetisation (Multi-Gateway) ──────────────────────────────────

enum PlanType {
  FREE
  SEEKER_PREMIUM
  SEEKER_ELITE
  MENTOR_MARKETPLACE
  RECRUITER_STARTER
  RECRUITER_PRO
  RECRUITER_ENTERPRISE
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  PAUSED
  EXPIRED
}

enum BillingPeriod {
  MONTHLY
  ANNUAL
}

model UserSubscription {
  id                  String             @id @default(cuid())
  userId              String             @unique
  plan                PlanType           @default(FREE)
  planKey             String?
  status              SubscriptionStatus @default(ACTIVE)
  gateway             PaymentGateway?
  gatewaySubId        String?
  gatewayCustomerId   String?
  billingPeriod       BillingPeriod?
  pricePaidPaise      Int?
  startsAt            DateTime?
  expiresAt           DateTime?
  cancelledAt         DateTime?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gatewaySubId])
}

model ResumeOptimisationCredit {
  id          String   @id @default(cuid())
  userId      String
  balance     Int      @default(0)
  paymentId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId])
}

model CompanySubscription {
  id                  String             @id @default(cuid())
  companyId           String             @unique
  plan                PlanType           @default(RECRUITER_STARTER)
  status              SubscriptionStatus @default(ACTIVE)
  gateway             PaymentGateway?
  gatewaySubId        String?
  gatewayCustomerId   String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  seats               Int                @default(1)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  company             Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model PaymentEvent {
  id              String         @id @default(cuid())
  userId          String?
  companyId       String?
  gateway         PaymentGateway
  gatewayEventId  String         @unique
  gatewayOrderId  String?
  amount          Int
  currency        String         @default("INR")
  status          PaymentStatus
  description     String?
  metadata        Json?
  createdAt       DateTime       @default(now())

  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([companyId])
  @@index([gatewayEventId])
}

model JobBoost {
  id            String         @id @default(cuid())
  jobPostId     Int
  companyId     String
  boostType     String
  startsAt      DateTime
  endsAt       DateTime
  amountPaid    Int
  gateway       PaymentGateway
  gatewayPayId  String
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())

  jobPost       JobPost        @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([jobPostId])
  @@index([companyId])
  @@index([endsAt])
}

model ResumeUnlock {
  id           String         @id @default(cuid())
  recruiterId  String
  seekerId     String
  companyId    String
  amountPaid   Int
  gateway      PaymentGateway
  gatewayPayId String
  unlockedAt   DateTime       @default(now())

  recruiter    User           @relation("RecruiterUnlocks", fields: [recruiterId], references: [id], onDelete: Cascade)
  seeker       User           @relation("SeekerUnlocks", fields: [seekerId], references: [id], onDelete: Cascade)
  company      Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, seekerId])
  @@index([recruiterId])
  @@index([companyId])
}

// ─── Phase 5A: Profile Fit Score (JD Fit Score) ─────────────────────────────

model FitScore {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostId        Int
  jobPost          JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  overallScore     Int
  skillsScore      Int
  experienceScore  Int
  educationScore   Int
  keywordsScore    Int

  skillGaps        Json     // FitGapItem[] — missing/weak skills
  experienceGaps   Json     // FitGapItem[] — experience shortfalls
  keywordGaps      Json     // FitGapItem[] — missing keywords
  strengths        Json     // string[] — what the seeker does well for this role

  profileVersion   String?  // hash of profile at time of scoring (for cache invalidation)
  promptVersion    String   @default("1.0.0")
  computedAt       DateTime @default(now())
  expiresAt        DateTime // computedAt + 7 days

  @@unique([userId, jobPostId])
  @@index([userId])
  @@index([jobPostId])
  @@index([expiresAt])
}

model FitScoreHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostId    Int
  jobPost      JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  overallScore Int
  recordedAt   DateTime @default(now())

  @@index([userId, recordedAt])
}

// ─── Phase 6: Application System ────────────────────────────────────────────

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model JobApplication {
  id              String            @id @default(cuid())
  jobPostId       Int
  jobPost         JobPost           @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  applicantId     String
  applicant       User              @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  resumeVersionId String?
  resumeVersion   ResumeVersion?    @relation(fields: [resumeVersionId], references: [id], onDelete: SetNull)

  coverLetter     String?           @db.Text
  coverLetterId   String?
  coverLetterRef  CoverLetter?      @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)
  responses       Json?             // ScreeningResponse[]

  status          ApplicationStatus @default(SUBMITTED)
  statusUpdatedAt DateTime          @default(now())
  recruiterNotes  String?           @db.Text
  fitScoreSnapshot Int?
  applicationTimeline Json?         // [{ status: string, at: string }] — status transition history
  isAnonymous    Boolean           @default(false) // Phase 18B: hide name until shortlisted

  submittedAt     DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  interviewReviews InterviewReview[]
  interviewScorecards InterviewScorecard[]
  boardSource        JobBoardApplicantSource?  // BL-24: source attribution

  @@unique([jobPostId, applicantId])
  @@index([jobPostId, status])
  @@index([applicantId, submittedAt])
  @@index([status])
}

// BL-24: Multi-Board Job Syndication
enum JobBoardSyndicationStatus {
  PENDING
  LIVE
  FAILED
  EXPIRED
  PAUSED
}

model JobBoardSyndication {
  id           String                    @id @default(cuid())
  jobPostId    Int
  jobPost      JobPost                   @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  board        String                    // NAUKRI | LINKEDIN | INDEED | FOUNDIT | etc
  status       JobBoardSyndicationStatus @default(PENDING)
  postedAt     DateTime?
  expiresAt   DateTime?
  costPaidPaise Int?
  trackingUrl  String?
  applicantCount Int                     @default(0)
  viewCount    Int                       @default(0)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([jobPostId, board])
  @@index([jobPostId])
  @@index([board])
  @@index([status])
}

model JobBoardApplicantSource {
  id             String         @id @default(cuid())
  applicationId  String         @unique
  application    JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  board          String
  clickedAt      DateTime       @default(now())

  @@index([board])
}

// Phase 18B: Employee referral for a job
enum ReferralOutcome {
  PENDING
  APPLIED
  SHORTLISTED
  HIRED
  EXPIRED
}

model JobReferral {
  id             String          @id @default(cuid())
  referrerId     String
  referredEmail  String
  jobPostId      Int
  outcome        ReferralOutcome @default(PENDING)
  referredAt     DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  referrer User    @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  jobPost  JobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@index([jobPostId])
  @@index([referrerId])
}

// ─── Phase 16B: Recruiter Intelligence & Hiring Analytics ───────────────────

enum ScorecardRecommendation {
  STRONG_YES
  YES
  UNDECIDED
  NO
  STRONG_NO
}

model HiringAnalyticsSnapshot {
  id            String   @id @default(cuid())
  jobPostId     Int
  jobPost       JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshotDate  DateTime @default(now())

  totalApplicants     Int @default(0)
  totalViewed         Int @default(0)
  totalShortlisted    Int @default(0)
  totalInterview      Int @default(0)
  totalOffered        Int @default(0)
  totalHired          Int @default(0)
  totalRejected       Int @default(0)

  avgDaysToFirstView      Float?
  avgDaysToShortlist      Float?
  avgDaysToInterview      Float?
  avgDaysToOffer          Float?
  avgDaysToHire           Float?

  createdAt DateTime @default(now())

  @@index([jobPostId])
  @@index([companyId])
  @@index([snapshotDate])
}

model InterviewScorecard {
  id               String   @id @default(cuid())
  jobApplicationId String
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  recruiterId      String
  recruiter        User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  jobPostId        Int
  jobPost          JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  technicalScore      Int?
  communicationScore  Int?
  cultureScore        Int?
  problemSolvingScore Int?
  overallScore        Int?

  notes           String?   @db.Text
  recommendation  ScorecardRecommendation @default(UNDECIDED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jobApplicationId, recruiterId])
  @@index([jobPostId])
  @@index([recruiterId])
}

model DIMetricsSnapshot {
  id           String   @id @default(cuid())
  jobPostId    Int
  jobPost      JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshotDate DateTime @default(now())

  stage       String   // APPLIED | SHORTLISTED | HIRED
  locationDistribution  Json    // { "Bangalore": 12, "Mumbai": 8, ... }
  educationDistribution Json   // { "BTech": 15, "MBA": 6, ... }
  genderDistribution    Json?  // { "Male": 18, "Female": 9, "Not specified": 5 }
  totalCount  Int

  createdAt DateTime @default(now())

  @@index([jobPostId])
  @@index([companyId])
}

// ─── Phase 11: AI Features (Cover Letter, Interview Prep, Profile Optimiser, Recommendations) ───

model CoverLetter {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostId       Int
  jobPost         JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  content         String   @db.Text
  tone            String
  generatedFrom   String   // resumeVersionId used, or 'profile'
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobApplications JobApplication[]

  @@unique([userId, jobPostId])
  @@index([userId])
  @@index([jobPostId])
}

model InterviewPrep {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostId       Int
  jobPost         JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  expectQuestions Json     // array of { question, category, why }
  askQuestions    Json     // array of { question }
  createdAt       DateTime @default(now())

  @@unique([userId, jobPostId])
  @@index([userId])
  @@index([jobPostId])
}

model ProfileOptimiserResult {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  result        Json     // { headline, summary, skillGaps, bulletSuggestions }
  analysedAt    DateTime @default(now())
  promptVersion String

  @@index([userId])
}

model JobDismissal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobPostId Int
  jobPost   JobPost  @relation(fields: [jobPostId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobPostId])
  @@index([userId])
  @@index([jobPostId])
}

// ─── Phase 9: Career Graph & Contextual Networking ────────────────────────

enum ConnectionType {
  PEER
  MENTOR
  COLLEAGUE
  INTERVIEWER
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum SignalType {
  ROLE_MOVE
  NEW_JOB_AT_FOLLOW
  NETWORK_JOIN
  FIT_SCORE_IMPROVE
  CONNECTION_HIRED
  MENTOR_AVAILABLE
  MENTOR_PROFILE_CREATED
  MENTOR_SESSION_COMPLETED
  REVIEW_SUBMITTED
}

model Connection {
  id            String           @id @default(cuid())
  requesterId   String
  recipientId   String
  type          ConnectionType    @default(PEER)
  contextTag    String?
  status        ConnectionStatus  @default(PENDING)
  connectedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  requester     User             @relation("ConnectionsInitiated", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient     User             @relation("ConnectionsReceived", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status])
  @@index([requesterId, status])
}

model CompanyFollow {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model Conversation {
  id             String     @id @default(cuid())
  participantA   String
  participantB   String
  lastMessageAt  DateTime?
  createdAt      DateTime   @default(now())

  messages Message[]
  userA    User      @relation("ConversationA", fields: [participantA], references: [id], onDelete: Cascade)
  userB    User      @relation("ConversationB", fields: [participantB], references: [id], onDelete: Cascade)

  @@unique([participantA, participantB])
  @@index([participantA, lastMessageAt])
  @@index([participantB, lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String       @db.Text
  readAt         DateTime?
  jobPostId      Int?
  companyId      String?
  sessionId      String?
  createdAt      DateTime     @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  jobPost       JobPost?     @relation(fields: [jobPostId], references: [id], onDelete: SetNull)
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model CareerSignal {
  id        String     @id @default(cuid())
  userId    String
  actorId   String?
  type      SignalType
  companyId String?
  jobPostId Int?
  metadata  Json?
  seen      Boolean    @default(false)
  createdAt DateTime  @default(now())

  user    User     @relation("SignalFeed", fields: [userId], references: [id], onDelete: Cascade)
  actor   User?    @relation("SignalActor", fields: [actorId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  jobPost JobPost? @relation(fields: [jobPostId], references: [id], onDelete: SetNull)

  @@index([userId, seen, createdAt])
  @@index([actorId])
}

// ─── Phase 9B: Mentorship Layer ─────────────────────────────────────────────

enum MentorTransition {
  IC_TO_MANAGER
  MANAGER_TO_IC
  STARTUP_TO_LARGE
  LARGE_TO_STARTUP
  INDIA_TO_GLOBAL
  DOMAIN_SWITCH
  INDUSTRY_SWITCH
  FIRST_JOB
  LEVEL_UP
  RETURN_TO_WORK
}

enum MentorStyle {
  STRUCTURED
  ASYNC
  AD_HOC
}

enum SessionFormat {
  VIDEO_CALL
  VOICE_CALL
  ASYNC_CHAT
  IN_PERSON
}

enum SessionStatus {
  REQUESTED
  ACCEPTED
  SCHEDULED

// ─── GST Invoicing ────────────────────────────────────────────────────────

enum GstType {
  CGST_SGST
  IGST
}

enum InvoiceStatus {
  DRAFT
  FINALISED
  VOID
}

enum InvoicePaymentType {
  SUBSCRIPTION
  MARKETPLACE_ORDER
  MENTORSHIP_TRANCHE
}

model Invoice {
  id                 String              @id @default(cuid())
  invoiceNumber      String              @unique
  invoiceDate        DateTime            @default(now())
  financialYear      String

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  payerName          String
  payerEmail         String
  payerAddress       String?
  payerGstin         String?
  payerStateCode     String?

  lineItems          InvoiceLineItem[]

  subtotalPaise      Int
  cgstPaise          Int
  sgstPaise          Int
  igstPaise          Int
  totalPaise        Int

  gstType            GstType
  paymentType        InvoicePaymentType
  paymentId          String?
  orderId           String?

  subscriptionId    String?
  marketplaceOrderId String?
  escrowTrancheId   String?

  pdfS3Key          String?
  pdfGeneratedAt    DateTime?

  status             InvoiceStatus       @default(DRAFT)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId])
  @@index([financialYear])
  @@index([status])
  @@index([invoiceDate])
}

model InvoiceLineItem {
  id              String  @id @default(cuid())
  invoice         Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId       String
  description     String
  sacCode         String  @default("998314")
  quantity        Int     @default(1)
  unitPricePaise  Int
  totalPaise      Int

  @@index([invoiceId])
}

model InvoiceSequence {
  id            String   @id @default(cuid())
  financialYear String   @unique
  lastSequence  Int      @default(0)
}

model BillingProfile {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String   @unique
  gstin           String?
  gstinVerified   Boolean  @default(false)
  legalName       String?
  billingAddress  String?
  stateCode       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

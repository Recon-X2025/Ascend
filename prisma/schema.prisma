enum ProviderStatus {
  PENDING_REVIEW
  ACTIVE
  SUSPENDED
}

enum ProviderType {
  RESUME_REVIEWER
  MOCK_INTERVIEWER
  CAREER_COACH
}

model MarketplaceProvider {
  id              String          @id @default(cuid())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String          @unique
  type            ProviderType
  status          ProviderStatus  @default(PENDING_REVIEW)
  bio             String          @db.Text
  specialisations String[]
  languages       String[]
  pricePerSession Int
  currency        String          @default("INR")
  avgRating       Float?
  totalReviews    Int             @default(0)
  totalSessions   Int             @default(0)
  isAvailable     Boolean         @default(true)
  turnaroundHours Int?
  calendarUrl     String?
  adminNote       String?         @db.Text
  approvedAt      DateTime?
  suspendedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  resumeReviews   ResumeReviewOrder[]
  mockInterviews  MockInterviewBooking[]
  coachingSessions CoachingSession[]
  reviews         ProviderReview[]
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  IN_REVIEW
  DELIVERED
  DISPUTED
  REFUNDED
}

model ResumeReviewOrder {
  id              String             @id @default(cuid())
  seeker          User               @relation("SeekerResumeReviews", fields: [seekerId], references: [id], onDelete: Cascade)
  seekerId        String
  provider        MarketplaceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId      String
  resumeVersionId String?
  resumeUrl       String
  careerGoal      String             @db.Text
  status          OrderStatus        @default(PENDING_PAYMENT)
  paymentEventId  String?
  platformFee     Int
  providerPayout  Int
  feedbackUrl     String?
  deliveredAt     DateTime?
  seekerRating    Int?
  seekerReview    String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([seekerId])
  @@index([providerId])
  @@index([status])
}

model MockInterviewBooking {
  id                  String             @id @default(cuid())
  seeker              User               @relation("SeekerMockInterviews", fields: [seekerId], references: [id], onDelete: Cascade)
  seekerId            String
  provider            MarketplaceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId          String
  durationMinutes     Int
  targetRole          String
  status              OrderStatus        @default(PENDING_PAYMENT)
  scheduledAt         DateTime?
  paymentEventId      String?
  platformFee         Int
  providerPayout      Int
  technicalScore      Int?
  communicationScore  Int?
  cultureScore        Int?
  problemSolvingScore Int?
  scorecardNotes      String?            @db.Text
  recordingConsent    Boolean            @default(false)
  deliveredAt         DateTime?
  seekerRating        Int?
  seekerReview        String?            @db.Text
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([seekerId])
  @@index([providerId])
  @@index([status])
}

model CoachingSession {
  id              String             @id @default(cuid())
  seeker          User               @relation("SeekerCoachingSessions", fields: [seekerId], references: [id], onDelete: Cascade)
  seekerId        String
  provider        MarketplaceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId      String
  topic           String
  durationMinutes Int
  status          OrderStatus        @default(PENDING_PAYMENT)
  scheduledAt     DateTime?
  paymentEventId  String?
  platformFee     Int
  providerPayout  Int
  sessionNotes    String?            @db.Text
  seekerRating    Int?
  seekerReview    String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([seekerId])
  @@index([providerId])
  @@index([status])
}

model ProviderReview {
  id          String              @id @default(cuid())
  provider    MarketplaceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId  String
  reviewer    User                @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId  String
  rating      Int
  review      String?             @db.Text
  serviceType String
  orderId     String
  createdAt   DateTime            @default(now())

  @@unique([reviewerId, orderId])
  @@index([providerId])
}

model CourseRecommendation {
  id            String    @id @default(cuid())
  skill         String
  title         String
  provider      String
  url           String
  affiliateCode String?
  priceInr      Int?
  durationHours Int?
  level         String?
  language      String    @default("en")
  isActive      Boolean   @default(true)
  clickCount    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clicks        CourseClick[]

  @@index([skill])
  @@index([isActive])
}

model CourseClick {
  id          String               @id @default(cuid())
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?
  course      CourseRecommendation  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  skill       String
  createdAt   DateTime             @default(now())

  @@index([courseId])
  @@index([userId])
}

enum BadgeStatus {
  PENDING_VERIFICATION
  ACTIVE
  EXPIRED
  REVOKED
}

model ProfileBadge {
  id              String      @id @default(cuid())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  provider        String
  skill           String
  score           Float?
  percentile      Float?
  badgeUrl        String?
  verificationUrl String?
  issuedAt        DateTime
  expiresAt       DateTime?
  status          BadgeStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())

  @@unique([userId, provider, skill])
  @@index([userId])
  @@index([status])
}


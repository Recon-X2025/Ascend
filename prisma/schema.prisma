// M-11: Mentor Reputation & Tier System
enum MentorTier {
  RISING       // 0–4 verified outcomes
  ESTABLISHED  // 5–9 verified outcomes
  ELITE        // 10+ verified outcomes
}

model MentorProfile {
  id                    String                @id @default(cuid())
  userId                String                @unique
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive              Boolean               @default(true)
  maxMenteesPerMonth    Int                   @default(3)
  currentMenteeCount    Int                   @default(0)

  currentRole           String
  currentCompany        String?
  previousRole          String?
  transitionType        MentorTransition?
  yearsOfExperience     Int

  currentCity           String?
  previousCity          String?
  crossBorderExperience Boolean               @default(false)
  countriesWorkedIn     String[]              @default([])

  mentoringStyles       MentorStyle[]         @default([])
  sessionFormats        SessionFormat[]       @default([])
  languages             String[]              @default(["English"])
  focusAreas            MentorFocusArea[]     @default([])

  totalSessions         Int                   @default(0)
  totalMentees          Int                   @default(0)
  averageRating         Float?
  featuredTestimonial   String?               @db.Text

  isVerified            Boolean               @default(false)
  verifiedAt            DateTime?

  verificationStatus   VerificationStatus   @default(UNVERIFIED)
  isDiscoverable        Boolean               @default(false)
  verification          MentorVerification?

  // M-2: Transition record (structured)
  fromRole              String?
  fromCompanyType       MentorCompanyType?
  fromIndustry          String?
  fromCity              String?
  toRole                String?
  toCompanyType         MentorCompanyType?
  toIndustry            String?
  toCity                String?
  transitionDurationMonths Int?
  transitionYear        Int?
  transitionBadge       TransitionBadge       @default(SELF_REPORTED)

  // M-2: Key factors (20–200 chars each)
  keyFactor1            String?               @db.VarChar(200)
  keyFactor2            String?               @db.VarChar(200)
  keyFactor3            String?               @db.VarChar(200)

  // M-2: Mentor statements (50–400 chars each)
  statementTransitionMade   String?            @db.VarChar(400)
  statementWishIKnew        String?            @db.VarChar(400)
  statementCanHelpWith     String?            @db.VarChar(400)
  statementCannotHelpWith  String?            @db.VarChar(400)

  // M-2: Capacity (maxActiveMentees moved to M-11 tier — synced from tier)
  engagementPreference  EngagementLength[]    @default([])
  sessionFrequency      SessionFrequency?
  timezone              String                @default("Asia/Kolkata")

  // M-2: Focus & geography
  m2FocusAreas         M2FocusArea[]         @default([])
  geographyScope       GeographyScope?
  geographyCountries   String[]              @default([])

  // M-2: isPublic set only by admin on verification approve
  isPublic              Boolean               @default(false)

  // M-10: Outcome verification stats (recalculated from VERIFIED outcomes)
  verifiedOutcomeCount  Int                   @default(0)
  totalEngagements      Int                   @default(0)
  avgTimeToOutcomeDays  Float?
  outcomeTypes          String[]              @default([]) // e.g. ["SWE → PM", "IC → Manager"], max 10

  // M-11: Tier & reputation (system-calculated; admin can override)
  tier                  MentorTier            @default(RISING)
  tierUpdatedAt         DateTime?
  tierOverriddenByAdmin Boolean               @default(false)
  tierOverrideNote      String?               @db.Text
  disputeRate           Float?                // upheld disputes / total engagements (rolling)
  stenoRate             Float?                // M-7: sessions with Steno / total sessions — do not wire demotion until M-7
  maxActiveMentees      Int                   @default(2)   // synced from tier: RISING=2, ESTABLISHED=4, ELITE=6
  activeMenteeCount     Int                   @default(0)   // maintained when contract ACTIVE / terminal

  // M-13: Mentor Monetisation Unlock
  monetisationStatus    MentorMonetisationStatus?
  sessionFeePaise       Int?                  // mentor-set fee (validated against floor/ceiling)
  canChargeMentees      Boolean               @default(false) // true = isUnlocked AND MENTOR_MARKETPLACE plan
  seoBoosts             MentorSeoBoost[]
  monthlyReportSentAt   DateTime?
  upheldDisputeCount    Int                   @default(0)   // M-9: from getMentorUpheldCount

  sessions              MentorSession[]
  availability          MentorAvailability[]
  availabilityWindows   AvailabilityWindow[]
  applications          MentorApplication[]
  circles               MentorshipCircle[]     // M-12

  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

// BL-7: Mentor Follow — seekers follow mentors without starting an application
model MentorFollow {
  id           String   @id @default(cuid())
  userId       String   // follower (seeker)
  mentorUserId String   // mentor being followed
  followedAt   DateTime @default(now())

  user       User @relation("MentorFollowsAsFollower", fields: [userId], references: [id], onDelete: Cascade)
  mentorUser User @relation("MentorFollowsAsMentor", fields: [mentorUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mentorUserId])
  @@index([mentorUserId])
  @@index([userId])
}

// BL-8: Mentor Posts — mentors publish short insights; followers see in feed
model MentorPost {
  id           String   @id @default(cuid())
  mentorUserId String
  content      String   @db.Text
  imageUrl     String?  // optional image URL (storage or external)
  createdAt    DateTime @default(now())

  mentorUser User @relation("MentorPosts", fields: [mentorUserId], references: [id], onDelete: Cascade)

  @@index([mentorUserId])
  @@index([createdAt])
}

// BL-13: Creator Mode — long-form articles and newsletters
model MentorArticle {
  id           String    @id @default(cuid())
  mentorUserId String
  title        String
  slug         String
  content      String    @db.Text
  excerpt      String?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  mentorUser User @relation("MentorArticles", fields: [mentorUserId], references: [id], onDelete: Cascade)

  @@unique([mentorUserId, slug])
  @@index([mentorUserId])
  @@index([publishedAt])
}

model MentorNewsletter {
  id           String    @id @default(cuid())
  mentorUserId String
  subject      String
  content      String    @db.Text
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  mentorUser User @relation("MentorNewsletters", fields: [mentorUserId], references: [id], onDelete: Cascade)

  @@index([mentorUserId])
  @@index([sentAt])
}

model MentorNewsletterSubscriber {
  id           String   @id @default(cuid())
  mentorUserId String
  email        String
  userId       String?
  subscribedAt DateTime @default(now())

  mentorUser User  @relation("MentorNewsletterSubscribers", fields: [mentorUserId], references: [id], onDelete: Cascade)
  user       User? @relation("NewsletterSubscriptions", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([mentorUserId, email])
  @@index([mentorUserId])
}

// M-13: Mentor Monetisation Unlock
enum SeoBoostType {
  MONTHLY_RECURRING
  ONE_TIME_30_DAYS
  ONE_TIME_14_DAYS
}

model MentorMonetisationStatus {
  id                    String                @id @default(cuid())
  mentor                MentorProfile         @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  mentorId              String                @unique
  isUnlocked            Boolean               @default(false)
  unlockedAt            DateTime?
  lockedReason          String?
  reLockedAt            DateTime?
  verifiedOutcomeCount  Int                    @default(0)
  stenoRate             Float?
  upheldDisputeCount    Int                    @default(0)
  monthsOnPlatform      Int                    @default(0)
  reVerificationCurrent Boolean               @default(false)
  lastCheckedAt         DateTime              @default(now())

  @@index([mentorId])
}

model MentorSeoBoost {
  id                    String                @id @default(cuid())
  mentor                MentorProfile         @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  mentorId              String
  boostType             SeoBoostType
  pricePaise            Int
  startDate             DateTime
  endDate               DateTime
  active                Boolean               @default(true)
  razorpayPaymentId     String?
  createdAt             DateTime              @default(now())

  @@index([mentorId])
  @@index([endDate, active])
}

// M-11: Tier change log (system or admin)
model MentorTierHistory {
  id            String      @id @default(cuid())
  mentor        User        @relation("MentorTierHistory", fields: [mentorId], references: [id], onDelete: Cascade)
  mentorId      String
  previousTier  MentorTier
  newTier       MentorTier
  reason        String      // WEEKLY_CALC | ADMIN_OVERRIDE | DEMOTION_DISPUTE_RATE | DEMOTION_VERIFICATION_LAPSED | OUTCOME_VERIFIED
  triggeredBy   String?     // adminId if admin override
  createdAt     DateTime    @default(now())

  @@index([mentorId])
  @@index([createdAt])
}

enum MentorApplicationStatus {
  PENDING           // submitted, awaiting mentor response
  QUESTION_ASKED   // mentor asked one question, awaiting mentee answer
  ACCEPTED         // mentor accepted
  DECLINED         // mentor declined
  EXPIRED          // no mentor response within 5 days
  WITHDRAWN        // mentee withdrew
}

enum ContractStatus {
  PENDING_MENTOR_SIGNATURE
  PENDING_MENTEE_SIGNATURE
  ACTIVE
  COMPLETED
  DISPUTED
  TERMINATED_BY_MENTOR
  TERMINATED_BY_MENTEE
  VOID
  PAUSED   // M-16: ops intervention — temporarily suspended
}

// M-8: Session rhythm enums
enum EngagementType {
  SPRINT   // 30 days, 4 sessions, 1 milestone
  STANDARD // 60 days, 6 sessions, 2 milestones
  DEEP     // 90 days, 8 sessions, 3 milestones
}

enum MilestoneType {
  GOAL_SETTING // Session 1 mandatory — generates GoalDocument
  MID         // Mid-engagement check-in (Standard: 1, Deep: 2)
  FINAL       // Final outcome review — generates OutcomeDocument
}

enum MilestoneStatus {
  PENDING
  MENTOR_FILED
  MENTEE_FILED
  COMPLETE // Both filed
}

enum DocumentType {
  GOAL_DOCUMENT
  OUTCOME_DOCUMENT
}

// M-12: Contract source — STANDARD from MentorApplication, CIRCLE from CircleMember
enum ContractType {
  STANDARD
  CIRCLE
}

// M-12: Mentorship Circles
enum CircleStatus {
  DRAFT
  OPEN
  LOCKED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CircleMemberStatus {
  APPLIED
  ACCEPTED
  CONFIRMED
  DECLINED
  WITHDRAWN
}

model MentorshipContract {
  id                  String          @id @default(cuid())
  mentorApplicationId String?         @unique
  mentorApplication   MentorApplication? @relation(fields: [mentorApplicationId], references: [id])
  circleMemberId      String?         @unique
  circleMember        CircleMember?   @relation("CircleMemberContract", fields: [circleMemberId], references: [id], onDelete: SetNull)
  contractType        ContractType    @default(STANDARD)

  mentorUserId        String
  mentor              User            @relation("MentorContracts", fields: [mentorUserId], references: [id])
  menteeUserId        String
  mentee              User            @relation("MenteeContracts", fields: [menteeUserId], references: [id])

  status              ContractStatus  @default(PENDING_MENTOR_SIGNATURE)

  // M-8: Engagement rhythm
  engagementType    EngagementType  @default(STANDARD)
  engagementStart   DateTime?
  engagementEnd     DateTime?
  sessions          EngagementSession[]
  milestones        EngagementMilestone[]
  documents         EngagementDocument[]

  // Contract content (snapshot at generation — immutable after signing)
  contractContent     Json            // Full structured contract data
  tcVersion           String          // Platform T&C version locked at generation

  // PDF
  pdfUrl              String?         // S3 URL — set after both signatures
  pdfHash             String?         // SHA-256 of PDF — set after generation, verified on every access
  pdfGeneratedAt      DateTime?

  // Signing windows
  mentorSignDeadline  DateTime?       // Set on generation: now + 48hrs
  menteeSignDeadline  DateTime?       // Set after mentor signs: mentor sign time + 48hrs

  // Timestamps
  generatedAt         DateTime        @default(now())
  activatedAt         DateTime?
  completedAt         DateTime?
  voidedAt            DateTime?
  terminatedAt        DateTime?
  terminatedBy        String?         // userId

  signatures          ContractSignature[]

  // M-10: One outcome per engagement
  outcome              MentorshipOutcome?
  certificate          MentorCertificate?  // BL-14

  // M-6: Agreed fee (nullable for backward compat)
  agreedFeePaise       Int?

  // M-6: Escrow
  escrow               MentorshipEscrow?

  // M-9: Escrow disputes
  disputes             MentorshipDispute[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([mentorUserId])
  @@index([menteeUserId])
  @@index([status])
}

// M-9: Dispute Resolution Engine
enum DisputeCategory {
  SESSION_DID_NOT_HAPPEN
  BELOW_MINIMUM_DURATION
  STENO_NOT_GENERATED
  OFF_PLATFORM_SOLICITATION
  COMMITMENTS_NOT_MET
}

enum DisputeStatus {
  PENDING_EVIDENCE
  EVIDENCE_ASSEMBLED
  AUTO_RESOLVING
  AUTO_RESOLVED
  PENDING_OPS
  RESOLVED
}

enum DisputeOutcome {
  UPHELD        // mentee wins — refund
  REJECTED      // mentor wins — release
  REJECTED_INVALID  // waived rights, invalid category, etc.
}

enum DisputeOpsReason {
  UPHELD
  REJECTED
  REJECTED_INVALID
}

enum StrikeType {
  MENTEE_DISPUTE_REJECTED   // rejected dispute = mentee strike
  MENTOR_DISPUTE_UPHELD     // upheld dispute = mentor strike
}

model MentorshipDispute {
  id                String            @id @default(cuid())
  contract          MentorshipContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId        String
  milestone         EngagementMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  milestoneId       String            @unique
  tranche           EscrowTranche     @relation(fields: [trancheId], references: [id], onDelete: Cascade)
  trancheId         String

  filedByUserId     String
  category          DisputeCategory
  description       String            @db.Text
  status            DisputeStatus     @default(PENDING_EVIDENCE)
  outcome           DisputeOutcome?
  opsReason         DisputeOpsReason?
  opsResolvedBy     String?
  opsResolvedAt     DateTime?
  opsNote           String?            @db.Text

  evidenceAssembledAt DateTime?
  autoResolvedAt    DateTime?
  resolvedAt        DateTime?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  evidence          DisputeEvidence[]
  strikes           DisputeStrike[]

  @@index([contractId])
  @@index([trancheId])
  @@index([status])
  @@index([filedByUserId])
}

model DisputeEvidence {
  id          String            @id @default(cuid())
  dispute     MentorshipDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  disputeId   String
  evidenceType String           // SESSION_RECORD, STENO_CONSENT, TRANSCRIPT, DURATION, MESSAGE_FLAGS, etc.
  content     Json              // immutable snapshot
  createdAt   DateTime          @default(now())

  @@index([disputeId])
}

model DisputeStrike {
  id          String            @id @default(cuid())
  dispute     MentorshipDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  disputeId   String
  userId      String
  strikeType  StrikeType
  createdAt   DateTime          @default(now())

  @@index([disputeId])
  @@index([userId])
  @@index([strikeType])
}

// M-6: Escrow & Payment Infrastructure
enum PaymentMode {
  ESCROW        // tranche-based, dispute rights intact
  FULL_UPFRONT  // full payment upfront, mentor paid immediately, mentee waives dispute rights
}

enum EscrowStatus {
  PENDING_PAYMENT   // Order created, awaiting Razorpay capture
  FUNDED            // Payment captured, funds held (ESCROW mode)
  COMPLETED         // All done (FULL_UPFRONT immediate completion, or ESCROW all tranches released)
  TERMINATED        // Early termination — partial refund/release
  VOIDED            // Contract voided before payment
}

enum TrancheStatus {
  HELD              // Funds held, awaiting release
  PENDING_RELEASE   // Milestone complete, mentee confirm or 7-day auto
  FROZEN            // Mentee disputed — ops review
  RELEASED          // Transferred to mentor
  REFUNDED          // Returned to mentee
}

enum MovementType {
  IN                 // Funds in (mentee payment, refund reversal)
  OUT                // Funds out (to mentor, refund to mentee)
  PLATFORM_FEE       // ESCROW → PLATFORM
}

enum PaymentReasonCode {
  ESCROW_FUNDED
  TRANCHE_RELEASED
  TRANCHE_REFUNDED
  TERMINATION_REFUND
  TERMINATION_RELEASE
  OPS_OVERRIDE
  PILOT_WAIVER
  DISPUTE_RESOLVED_MENTOR   // M-9: dispute rejected — release to mentor
  DISPUTE_RESOLVED_MENTEE   // M-9: dispute upheld — refund to mentee
}

model MentorshipEscrow {
  id                  String        @id @default(cuid())
  contractId          String        @unique
  contract            MentorshipContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  razorpayOrderId     String?
  razorpayPaymentId   String?

  paymentMode         PaymentMode   @default(ESCROW)
  status              EscrowStatus  @default(PENDING_PAYMENT)
  totalAmountPaise    Int
  platformFeePaise    Int           @default(0)
  mentorPayoutPaise   Int           @default(0)
  mentorId            String
  mentor              User          @relation("EscrowMentor", fields: [mentorId], references: [id])
  menteeId            String
  mentee              User          @relation("EscrowMentee", fields: [menteeId], references: [id])

  pilotFeeWaived      Boolean         @default(false)
  mentorTierAtSigning String?
  feeRate             Float?

  fundedAt            DateTime?
  terminatedAt        DateTime?
  voidedAt            DateTime?

  tranches            EscrowTranche[]
  movements           PaymentMovement[]
  acknowledgement     PaymentModeAcknowledgement?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([contractId])
  @@index([mentorId])
  @@index([menteeId])
  @@index([status])
}

model PaymentModeAcknowledgement {
  id              String             @id @default(cuid())
  escrow          MentorshipEscrow   @relation(fields: [escrowId], references: [id])
  escrowId        String             @unique
  mentee          User               @relation(fields: [menteeId], references: [id])
  menteeId        String
  paymentMode     PaymentMode
  waiverText      String             @db.Text
  acknowledgedAt  DateTime           @default(now())
  ipAddress       String?

  @@index([menteeId])
}

model EscrowTranche {
  id                  String          @id @default(cuid())
  escrowId            String
  escrow              MentorshipEscrow @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  trancheNumber       Int             // 1, 2, or 3
  amountPaise          Int
  percentPct           Int             // e.g. 33, 34, 50
  status               TrancheStatus   @default(HELD)
  platformFeePaise    Int             @default(0)
  mentorNetPaise      Int             @default(0)

  milestoneId         String?               @unique
  milestone           EngagementMilestone?   @relation(fields: [milestoneId], references: [id])
  autoReleaseAt       DateTime?
  releasedAt          DateTime?

  feeRecord           TrancheFeeRecord?
  disputes            MentorshipDispute[]

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([escrowId, trancheNumber])
  @@index([escrowId])
  @@index([status])
  @@index([autoReleaseAt])
}

model TrancheFeeRecord {
  id                  String          @id @default(cuid())
  trancheId           String          @unique
  tranche             EscrowTranche    @relation(fields: [trancheId], references: [id], onDelete: Cascade)

  mentorTierAtRelease String
  feeRateApplied      Float
  platformFeePaise    Int
  mentorNetPaise      Int
  pilotFeeWaived      Boolean
  paymentMode         PaymentMode
  releasedAt          DateTime

  createdAt           DateTime        @default(now())

  @@index([releasedAt])
  @@index([paymentMode])
}

model MentorshipRevenueSnapshot {
  id                   String   @id @default(cuid())
  date                 DateTime @unique

  totalReleasedPaise   Int
  platformFeePaise     Int
  mentorPayoutPaise    Int
  pilotWaivedPaise      Int
  tranchesReleased     Int
  byTier               Json
  byPaymentMode        Json

  createdAt            DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([date])
}

model PaymentMovement {
  id                  String            @id @default(cuid())
  escrowId            String
  escrow              MentorshipEscrow   @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  amountPaise         Int
  direction           MovementType
  reasonCode          PaymentReasonCode
  contractId          String
  trancheId           String?
  triggeredBy         String?           // userId or "SYSTEM"
  notes               String?          @db.Text

  createdAt           DateTime          @default(now())

  @@index([escrowId])
  @@index([contractId])
  @@index([reasonCode])
}

// M-10: Outcome verification & attribution
enum OutcomeStatus {
  PENDING_MENTEE   // Mentor submitted — awaiting mentee response
  VERIFIED         // Mentee confirmed
  DISPUTED         // Mentee disputed — ops review
  UNACKNOWLEDGED   // 7-day window passed, no mentee response
  OPS_REVIEWED     // Admin reviewed disputed outcome
}

enum OutcomeCheckInStatus {
  PENDING
  COMPLETED
  SKIPPED
}

model MentorshipOutcome {
  id                    String                @id @default(cuid())
  contract              MentorshipContract   @relation(fields: [contractId], references: [id])
  contractId            String                @unique
  mentor                User                  @relation("MentorOutcomes", fields: [mentorId], references: [id])
  mentorId              String
  mentee                User                  @relation("MenteeOutcomes", fields: [menteeId], references: [id])
  menteeId              String

  outcomeAchieved       Boolean
  transitionType        String                @db.VarChar(100)
  claimedOutcome        String                @db.VarChar(500)
  mentorReflection      String?               @db.VarChar(500)
  testimonialConsent    Boolean               @default(false)

  status                OutcomeStatus         @default(PENDING_MENTEE)
  menteeConfirmedAt     DateTime?
  menteeDisputedAt      DateTime?
  menteeNote            String?               @db.Text
  acknowledgementDeadline DateTime

  opsReviewedAt         DateTime?
  opsReviewedBy         String?
  opsDecision           String?               @db.VarChar(20) // UPHELD | OVERTURNED
  opsNote               String?               @db.Text

  checkInStatus         OutcomeCheckInStatus  @default(PENDING)
  checkInDueAt          DateTime?
  checkInCompletedAt    DateTime?
  checkInNote           String?               @db.Text
  checkInBadgeGranted   Boolean               @default(false)

  submittedAt           DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  successStory           TransitionSuccessStory? // BL-3
  certificate            MentorCertificate?     // BL-14

  @@index([mentorId])
  @@index([menteeId])
  @@index([status])
  @@index([acknowledgementDeadline])
}

// BL-14: Verified Career Certificates — Ascend-issued completion badges
model MentorCertificate {
  id               String   @id @default(cuid())
  contractId       String   @unique
  contract         MentorshipContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  outcomeId        String   @unique
  outcome          MentorshipOutcome  @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  menteeId         String
  mentee           User     @relation("MentorCertificates", fields: [menteeId], references: [id], onDelete: Cascade)
  verificationCode String   @unique
  issuedAt         DateTime @default(now())

  @@index([verificationCode])
  @@index([menteeId])
}

// BL-3: Transition Success Stories — consent-gated shareable cards from verified outcomes
model TransitionSuccessStory {
  id              String   @id @default(cuid())
  outcomeId       String   @unique
  outcome         MentorshipOutcome @relation(fields: [outcomeId], references: [id], onDelete: Cascade)
  slug            String   @unique  // short URL slug e.g. "x7k9m2"
  includeEmployer Boolean  @default(false)
  consentGivenAt  DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([slug])
}

// BL-10: Career Milestones — shareable cards for contract completed, tier achieved, etc.
enum CareerMilestoneType {
  CONTRACT_COMPLETED  // mentee completed mentorship
  TIER_ACHIEVED      // mentor reached new tier
}

model CareerMilestone {
  id             String             @id @default(cuid())
  type           CareerMilestoneType
  userId         String             // who achieved it
  user           User               @relation("CareerMilestones", fields: [userId], references: [id], onDelete: Cascade)
  entityId       String             // contractId or tierHistoryId
  slug           String             @unique
  metadata       Json               // { mentorName?, tier?, transitionType?, menteeName? }
  consentGivenAt DateTime           @default(now())
  createdAt      DateTime           @default(now())

  @@index([userId])
  @@index([slug])
}

// BL-9: Cohort Communities — open groups by transition path, lighter than M-12 Circles
model Cohort {
  id              String   @id @default(cuid())
  name            String   // e.g. "SWE → PM 2025"
  transitionPath  String   // e.g. "SWE → PM"
  slug            String   @unique
  description     String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members CohortMember[]
  threads CohortThread[]

  @@index([transitionPath])
  @@index([slug])
}

model CohortMember {
  id        String   @id @default(cuid())
  cohortId  String
  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("CohortMembers", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([cohortId, userId])
  @@index([cohortId])
  @@index([userId])
}

model CohortThread {
  id        String   @id @default(cuid())
  cohortId  String
  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("CohortThreads", fields: [authorId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([cohortId])
  @@index([authorId])
}

// M-7: Session Room, Steno & Evidence enums
enum ExceptionStatus {
  PENDING_ACKNOWLEDGEMENT
  ACKNOWLEDGED
  DECLINED
  EXPIRED
}

enum MessageFlagType {
  EXTERNAL_EMAIL
  PHONE_NUMBER
  EXTERNAL_VIDEO_LINK
  PAYMENT_SOLICITATION
}

enum StenoStatus {
  NOT_STARTED
  ACTIVE
  PARTIAL
  COMPLETED
  SKIPPED
}

model EngagementSession {
  id                    String        @id @default(cuid())
  contract              MentorshipContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId            String
  sessionNumber         Int            // 1–4/6/8 based on engagement type
  scheduledAt           DateTime?
  completedAt          DateTime?
  status                SessionStatus  @default(SCHEDULED)
  mentorNotes           String?        @db.Text // private to mentor
  sharedNotes           String?        @db.Text // visible to both after session
  durationMinutes       Int?           // actual duration (manual entry for now)
  // M-7: session evidence fields
  slotDurationMins      Int?           // agreed slot length (e.g. 45)
  effectiveDurationMins Int?           // overlap where both present
  carryOverMins         Int            @default(0)
  effectiveSlotMins      Int?           // slotDuration + carryOver
  stenoStatus           StenoStatus    @default(NOT_STARTED)
  sessionRoomId         String?       @unique
  sessionRoom           SessionRoom?   @relation(fields: [sessionRoomId], references: [id], onDelete: SetNull)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  joinLogs              SessionJoinLog[]
  stenoConsents         StenoConsentLog[]
  transcripts           SessionTranscript[]
  stenoExtractions      StenoExtraction[]
  sessionRecord         SessionRecord?
  exceptionNotes        SessionExceptionNote[]
  circleSessionId      String?
  circleSession        CircleSession?  @relation(fields: [circleSessionId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([circleSessionId])
}

model SessionRoom {
  id            String   @id @default(cuid())
  session       EngagementSession? // 1:1 back-relation (1:1 session)
  circleSession CircleSession?     // M-12: or circle group session
  dailyRoomName String @unique
  dailyRoomUrl  String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SessionJoinLog {
  id                 String   @id @default(cuid())
  session            EngagementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId          String
  userId             String
  dailyParticipantId String?
  joinedAt           DateTime
  leftAt             DateTime?
  durationSeconds    Int?     // computed when left
  createdAt          DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
}

model StenoConsentLog {
  id              String   @id @default(cuid())
  session         EngagementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  userId          String
  participantType String   // "MENTOR" | "MENTEE"
  acknowledged    Boolean
  ipAddress       String?
  createdAt       DateTime @default(now())

  @@unique([sessionId, userId])
  @@index([sessionId])
}

model SessionTranscript {
  id        String   @id @default(cuid())
  session   EngagementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  content   String   @db.Text // full transcript text
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model StenoExtraction {
  id         String   @id @default(cuid())
  session    EngagementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  summary    String?  @db.Text
  mentorCommitments  Json?  // string[]
  menteeCommitments  Json?  // string[]
  actionItems       Json?  // string[]
  nextSessionFocus   String? @db.Text
  goalProgressSignal String? @db.Text
  createdAt  DateTime @default(now())

  @@index([sessionId])
}

model SessionRecord {
  id           String   @id @default(cuid())
  session      EngagementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String   @unique
  s3Key       String
  sha256Hash  String   // immutable integrity
  generatedAt DateTime @default(now())

  @@index([sessionId])
}

model SessionExceptionNote {
  id         String         @id @default(cuid())
  session    EngagementSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  filedBy    String         // userId
  note       String         @db.Text
  status     ExceptionStatus @default(PENDING_ACKNOWLEDGEMENT)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  declinedAt    DateTime?
  declinedBy    String?
  expiresAt     DateTime?    // for acknowledgement window
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
}

model MessageFlag {
  id         String         @id @default(cuid())
  contractId String
  messageId  String
  senderId   String
  flagType   MessageFlagType
  createdAt  DateTime @default(now())

  @@index([contractId])
  @@index([messageId])
}

model EngagementMilestone {
  id               String           @id @default(cuid())
  contract         MentorshipContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId       String
  milestoneNumber  Int              // 1, 2, or 3
  type             MilestoneType
  dueDate          DateTime
  status           MilestoneStatus  @default(PENDING)
  mentorAssessment String?         @db.Text
  menteeAssessment String?         @db.Text
  mentorFiledAt    DateTime?
  menteeFiledAt    DateTime?
  completedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // M-6: Escrow tranche linked to this milestone (optional)
  escrowTranche    EscrowTranche?

  // M-9: One dispute per milestone (mentee only)
  dispute          MentorshipDispute?

  @@index([contractId])
}

model EngagementDocument {
  id            String    @id @default(cuid())
  contract      MentorshipContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId    String
  type          DocumentType
  content       Json      // structured — Goal or Outcome shape
  mentorSigned  Boolean   @default(false)
  menteeSigned   Boolean   @default(false)
  mentorSignedAt DateTime?
  menteeSignedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([contractId, type])
  @@index([contractId])
}

model ContractSignature {
  id           String             @id @default(cuid())
  contractId   String
  contract     MentorshipContract @relation(fields: [contractId], references: [id])

  signerUserId String
  signer       User               @relation("ContractSignatures", fields: [signerUserId], references: [id])
  signerRole   String             // "MENTOR" | "MENTEE"

  // OTP verification record
  otpRequestedAt DateTime
  otpVerifiedAt  DateTime
  ipAddress      String
  userAgent      String

  // Signature declaration
  declaration    String           // "I, [Full Name], agree to the terms of this Engagement Contract."

  createdAt      DateTime         @default(now())

  @@unique([contractId, signerRole])
  @@index([contractId])
  @@index([signerUserId])
}

model MentorApplication {
  id              String   @id @default(cuid())
  menteeId        String
  mentee          User     @relation("MenteeApplications", fields: [menteeId], references: [id], onDelete: Cascade)
  mentorProfileId String
  mentorProfile   MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)

  whyThisMentor       String    @db.Text
  goalStatement       String    @db.Text
  commitment         String    @db.Text
  timeline            String    @db.Text
  whatAlreadyTried    String    @db.Text

  mentorQuestion      String?   @db.Text
  menteeAnswer        String?   @db.Text
  declineReason       String?   @db.Text

  matchReason         String    @db.Text
  matchScore          Int

  matchScoreAtApplication Int?   // M-4: snapshot at apply time (ops only)
  matchDimensionsSnapshot Json?  // M-4: dimension breakdown at apply (ops only)

  status              MentorApplicationStatus @default(PENDING)

  submittedAt         DateTime  @default(now())
  mentorRespondedAt   DateTime?
  expiresAt           DateTime
  questionAskedAt     DateTime?
  answerSubmittedAt   DateTime?

  contract    MentorshipContract?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([menteeId, mentorProfileId])
  @@index([mentorProfileId, status])
  @@index([status, expiresAt])
}

// M-12: Mentorship Circles (Group Cohorts)
model MentorshipCircle {
  id              String       @id @default(cuid())
  mentorId        String
  mentor          User         @relation("MentorCircles", fields: [mentorId], references: [id], onDelete: Cascade)
  mentorProfileId String
  mentorProfile   MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  title           String
  description     String?       @db.Text
  maxMembers      Int          @default(6)
  feePaise        Int
  startDate       DateTime
  status          CircleStatus  @default(DRAFT)
  leadTimeDays    Int          @default(7)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  members         CircleMember[]
  sessions        CircleSession[]
  peerCheckIns    CirclePeerCheckIn[]

  @@index([mentorId])
  @@index([mentorProfileId])
  @@index([status])
  @@index([startDate])
}

model CircleMember {
  id              String           @id @default(cuid())
  circleId        String
  circle          MentorshipCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  menteeId        String
  mentee          User             @relation("CircleMembers", fields: [menteeId], references: [id], onDelete: Cascade)
  status          CircleMemberStatus @default(APPLIED)
  applicationNote String?          @db.Text
  contract        MentorshipContract? @relation("CircleMemberContract")  // 1:1 via contract.circleMemberId
  appliedAt       DateTime         @default(now())
  acceptedAt      DateTime?
  confirmedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  oneOnOneSlots   CircleOneOnOneSlot[]
  peerCheckInsFrom CirclePeerCheckIn[] @relation("PeerCheckInFrom")
  peerCheckInsTo   CirclePeerCheckIn[] @relation("PeerCheckInTo")

  @@unique([circleId, menteeId])
  @@index([circleId])
  @@index([menteeId])
  @@index([status])
}

model CircleSession {
  id             String        @id @default(cuid())
  circleId       String
  circle         MentorshipCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  sessionNumber  Int
  scheduledAt    DateTime?
  sessionRoomId  String?       @unique
  sessionRoom    SessionRoom?  @relation(fields: [sessionRoomId], references: [id], onDelete: SetNull)
  status         String        @default("SCHEDULED")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  memberSessions EngagementSession[]

  @@unique([circleId, sessionNumber])
  @@index([circleId])
  @@index([sessionRoomId])
}

model CircleOneOnOneSlot {
  id             String      @id @default(cuid())
  circleMemberId String
  circleMember   CircleMember @relation(fields: [circleMemberId], references: [id], onDelete: Cascade)
  sessionNumber  Int
  scheduledAt    DateTime?
  durationMins  Int         @default(30)
  status        String      @default("SCHEDULED")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([circleMemberId])
}

model CirclePeerCheckIn {
  id           String      @id @default(cuid())
  circleId     String
  circle       MentorshipCircle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  fromMemberId String
  fromMember   CircleMember @relation("PeerCheckInFrom", fields: [fromMemberId], references: [id], onDelete: Cascade)
  toMemberId   String
  toMember     CircleMember @relation("PeerCheckInTo", fields: [toMemberId], references: [id], onDelete: Cascade)
  content      String      @db.Text
  createdAt    DateTime    @default(now())

  @@index([circleId])
  @@index([fromMemberId])
  @@index([toMemberId])
}

model MenteeReadinessCheck {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  profileComplete       Boolean @default(false)
  careerContextComplete Boolean @default(false)
  transitionDeclared    Boolean @default(false)
  allGatesPassed        Boolean @default(false)

  targetFromRole        String?
  targetFromIndustry    String?
  targetToRole          String?
  targetToIndustry      String?
  targetCity            String?
  targetTimelineMonths  Int?

  lastCheckedAt DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AvailabilityWindow {
  id              String        @id @default(cuid())
  mentorProfileId String
  mentorProfile   MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       DayOfWeek
  startTime       String
  endTime         String
}

model MentorAvailability {
  id              String        @id @default(cuid())
  mentorProfileId String
  mentorProfile   MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)

  dayOfWeek       Int
  startTime       String
  endTime         String
  timezone        String        @default("Asia/Kolkata")
}

model MentorVerification {
  id                  String               @id @default(cuid())
  mentorProfileId     String               @unique
  status              VerificationStatus   @default(UNVERIFIED)
  submittedAt         DateTime?
  reviewedAt          DateTime?
  reviewedBy          String?
  linkedInUrl         String?
  linkedInChecked     Boolean              @default(false)
  employmentVerified  Boolean              @default(false)
  idVerified          Boolean              @default(false)
  verifiedAt          DateTime?
  nextReviewDue       DateTime?
  notes               String?              @db.Text
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  mentorProfile       MentorProfile        @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  documents           VerificationDocument[]
  auditLog            VerificationAuditLog[]
}

model VerificationDocument {
  id                     String                   @id @default(cuid())
  mentorVerificationId   String
  type                   VerificationDocumentType
  fileUrl                String
  fileName               String
  fileSize               Int
  mimeType               String
  uploadedAt             DateTime                 @default(now())
  reviewedAt             DateTime?
  accepted               Boolean?
  rejectionReason        String?                  @db.Text

  mentorVerification     MentorVerification       @relation(fields: [mentorVerificationId], references: [id], onDelete: Cascade)
}

model VerificationAuditLog {
  id                   String               @id @default(cuid())
  mentorVerificationId String
  adminId              String
  decision             VerificationDecision
  reasonCode           String
  note                 String?              @db.Text
  createdAt            DateTime             @default(now())

  mentorVerification   MentorVerification   @relation(fields: [mentorVerificationId], references: [id], onDelete: Cascade)
  admin                User                 @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model MentorSession {
  id                String        @id @default(cuid())
  mentorProfileId   String
  mentorProfile     MentorProfile @relation(fields: [mentorProfileId], references: [id], onDelete: Cascade)
  menteeId          String
  mentee            User          @relation("MenteeSession", fields: [menteeId], references: [id], onDelete: Cascade)

  status            SessionStatus @default(REQUESTED)
  sessionGoal       String        @db.Text
  sessionFormat     SessionFormat
  scheduledAt       DateTime?
  durationMinutes   Int           @default(45)
  meetingLink       String?

  menteeRating      Int?
  menteeFeedback    String?       @db.Text
  mentorNotes       String?       @db.Text
  outcomeAchieved   Boolean?

  careerSignalFired Boolean       @default(false)

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

// ─── M-16: Admin & Ops Layer ────────────────────────────────────────────────

enum MentorshipAuditCategory {
  VERIFICATION
  CONTRACT
  ENGAGEMENT
  OUTCOME
  DISPUTE
  TIER
  INTERVENTION
  SYSTEM
}

model MentorshipAuditLog {
  id           String                   @id @default(cuid())
  actor        User                     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  actorId      String
  action       String
  category     MentorshipAuditCategory
  entityType   String
  entityId     String
  previousState Json?
  newState     Json?
  reason       String?                  @db.Text
  actorIp      String?
  createdAt    DateTime                 @default(now())

  @@index([actorId])
  @@index([category])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum OpsAlertType {
  VERIFICATION_SLA_BREACH
  DISPUTE_SLA_BREACH
  OUTCOME_UNACKNOWLEDGED
  MENTOR_HIGH_DISPUTE_RATE
  MENTOR_LAPSED_REVERIFICATION
  ENGAGEMENT_STALLED
  CONTRACT_UNSIGNED
  STENO_FAILURE
  INVOICE_PDF_FAILED
  MENTEE_3_STRIKES  // M-9: 3 rejected disputes = ops alert
  ESCROW_DISPUTE_SLA_BREACH  // M-9: PENDING_OPS > 5 business days
}

model OpsAlert {
  id           String       @id @default(cuid())
  type         OpsAlertType
  severity     String       // "LOW" | "MEDIUM" | "HIGH" | "CRITICAL"
  entityType   String
  entityId     String
  message      String       @db.Text
  isRead       Boolean      @default(false)
  resolvedAt   DateTime?
  resolvedBy   User?        @relation(fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedById String?
  createdAt    DateTime     @default(now())

  @@index([type])
  @@index([severity])
  @@index([isRead])
  @@index([entityType, entityId])
}

// ─── M-15: Legal Framework & Compliance ────────────────────────────────────

enum LegalDocumentType {
  MENTORSHIP_MARKETPLACE_ADDENDUM
  MENTOR_CONDUCT_AGREEMENT
}

model LegalDocument {
  id          String             @id @default(cuid())
  type        LegalDocumentType
  version     String             // semver e.g. "1.0.0"
  title       String
  content     String             @db.Text // full legal text, markdown
  effectiveAt DateTime
  isActive    Boolean            @default(true) // only one active per type
  createdAt   DateTime          @default(now())

  signatures  LegalDocumentSignature[]

  @@index([type])
  @@index([type, isActive])
}

model LegalDocumentSignature {
  id         String        @id @default(cuid())
  document   LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  signedAt   DateTime      @default(now())
  ipAddress  String?
  userAgent  String?
  method     String        @default("OTP_EMAIL") // OTP_EMAIL | CHECKBOX (future)

  @@unique([documentId, userId])
  @@index([userId])
  @@index([documentId])
}

// ─── M-17: Mentorship Analytics & Insights ──────────────────────────────────

model MentorshipAnalyticsSnapshot {
  id                        String   @id @default(cuid())
  snapshotDate              DateTime @unique

  activeEngagements         Int
  newEngagementsThisWeek    Int
  completedEngagementsTotal Int
  stalledEngagements        Int
  averageEngagementDays     Float

  outcomesSubmittedTotal    Int
  outcomesVerifiedTotal     Int
  outcomesDisputedTotal     Int
  outcomeVerificationRate   Float
  avgTimeToOutcomeDays      Float
  sixMonthCheckinRate       Float

  totalMentors              Int
  verifiedMentors           Int
  activeMentors             Int
  mentorsByTier             Json
  avgDisputeRate            Float
  highDisputeRateMentors    Int

  sessionsCompletedTotal    Int
  sessionsCompletedThisWeek Int
  avgSessionsPerEngagement  Float
  milestonesCompletedRate  Float

  platformRevenuePaise      Int      @default(0)
  mentorPayoutsPaise        Int      @default(0)
  pilotWaivedRevenuePaise   Int      @default(0)

  createdAt                 DateTime @default(now())
}

model MentorAnalyticsSnapshot {
  id                       String   @id @default(cuid())
  mentor                   User     @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  mentorId                 String
  snapshotDate             DateTime

  applicationsReceived     Int
  applicationsAccepted     Int
  applicationsDeclined     Int
  acceptanceRate           Float

  engagementsActive        Int
  engagementsCompleted    Int
  engagementsTotal         Int
  completionRate           Float

  outcomesSubmitted        Int
  outcomesVerified         Int
  outcomesDisputed         Int
  outcomeRate              Float

  sessionsCompleted        Int
  avgSessionsPerEngagement  Float

  currentTier              String
  verifiedOutcomeCount     Int
  disputeRate              Float

  totalEarnedPaise         Int      @default(0)
  pendingEarnedPaise       Int      @default(0)
  inEscrowPaise            Int      @default(0)

  createdAt                DateTime @default(now())

  @@unique([mentorId, snapshotDate])
  @@index([mentorId])
  @@index([snapshotDate])
}

// ─── Phase 13: Admin Panel (Lite) ───────────────────────────────────────────
// ─── Phase 17: Trust, Safety & Compliance (extended) ────────────────────────

enum AuditCategory {
  AUTH
  DATA_ACCESS
  DATA_MUTATION
  ADMIN_ACTION
  PAYMENT
  MENTORSHIP
  SECURITY
  COMPLIANCE
  SYSTEM
}

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id          String   @id @default(cuid())
  adminId     String?  // kept for backward compat; use actorId for new entries
  action      String
  targetType  String
  targetId    String
  targetLabel String?

  // Phase 17: actor (who)
  actorId     String?
  actorRole   String?
  actorIp     String?
  actorAgent  String?  // User-Agent truncated to 500 chars

  // Phase 17: category & severity
  category    AuditCategory @default(ADMIN_ACTION)
  severity    AuditSeverity @default(INFO)

  // Phase 17: payload
  metadata       Json?
  previousState  Json?
  newState       Json?

  // Phase 17: outcome
  success    Boolean  @default(true)
  errorCode  String?

  createdAt  DateTime @default(now())

  admin  User? @relation(fields: [adminId], references: [id], onDelete: Cascade)
  actor  User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([actorId])
  @@index([category])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([severity])
}

model SecurityEvent {
  id       String   @id @default(cuid())

// ─── Phase 8: Salary Insights ─────────────────────────────────────────────────

model SalaryInsightCache {
  id              String   @id @default(cuid())
  cacheKey        String   @unique // e.g. "role:software-engineer:bangalore" or "company:google:all"
  data            Json     // cached aggregate result
  submissionCount Int
  jdSignalCount   Int
  computedAt      DateTime @default(now())
  expiresAt       DateTime // recompute after 24hrs

  @@index([cacheKey])
}

model CityMetric {
  id        String   @id @default(cuid())
